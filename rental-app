try{const raw=localStorage.getItem('cl_saved_v1');if(raw)clSavedList=JSON.parse(raw);}catch(e){}

function clGetSections(){return clMode==='out'?[...CL_SECTIONS,...CL_SECTIONS_OUT_EXTRA]:CL_SECTIONS;}

function clSetMode(m){
  clMode=m;
  clCheckData={};
  document.getElementById('cl-tab-in').className='mode-tab-cl'+(m==='in'?' active-in':'');
  document.getElementById('cl-tab-out').className='mode-tab-cl'+(m==='out'?' active-out':'');
  document.getElementById('cl-main-title').textContent=m==='in'?'입주 전 점검 체크리스트':'퇴거 후 점검 체크리스트';
  document.getElementById('cl-info-title').textContent=m==='in'?'입주 정보':'퇴거 정보';
  document.getElementById('cl-date-label').textContent=m==='in'?'입주일':'퇴거일';
  document.getElementById('cl-sig2-lbl').textContent=m==='in'?'세입자 (입주자)':'세입자 (퇴거자)';
  document.getElementById('cl-reason-wrap').style.display=m==='out'?'block':'none';
  clBuildSections();
  clUpdateSummary();
}

function clBuildSections(){
  const secs=clGetSections();
  const el=document.getElementById('cl-sections');
  if(!el)return;
  el.innerHTML=secs.map(sec=>`
    <div class="check-sec">
      <div class="cs-head" onclick="clToggleSec('${sec.id}')">
        <div class="cs-icon" style="background:${sec.bg};">${sec.icon}</div>
        <span class="cs-title">${sec.title}</span>
        <span class="cs-prog" id="cl-prog-${sec.id}">0/${sec.items.length}</span>
        <span class="cs-arrow open" id="cl-arrow-${sec.id}">›</span>
      </div>
      <div class="cs-body open" id="cl-body-${sec.id}">
        ${sec.items.map(it=>clBuildItem(it)).join('')}
      </div>
    </div>`).join('');
  clUpdateAllProgress();
}

function clBuildItem(item){
  const isOk = clCheckData[item.id]?.status==='ok';
  return `<div class="cl-item" id="clci-${item.id}" style="display:flex;align-items:center;gap:8px;padding:7px 10px;border-bottom:1px solid #f0f0f0;">
    <button onclick="clToggleOk('${item.id}',this)" style="width:36px;height:36px;border-radius:50%;border:2px solid ${isOk?'#1D9E75':'#ddd'};background:${isOk?'#1D9E75':'white'};color:${isOk?'white':'#ccc'};font-size:16px;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:inherit;">${isOk?'✓':'○'}</button>
    <div style="flex:1;font-size:13px;font-weight:${isOk?'700':'400'};color:${isOk?'#1D9E75':'#111'};">${item.name}</div>
    <input type="text" placeholder="메모" value="${clCheckData[item.id]?.memo||''}" oninput="clSetMemo('${item.id}',this.value)" style="width:120px;padding:5px 8px;border-radius:6px;border:1px solid #ddd;font-size:11px;font-family:inherit;outline:none;">
  </div>`;
}

function clToggleOk(id,btn){
  if(!clCheckData[id]) clCheckData[id]={status:null,memo:''};
  if(clCheckData[id].status==='ok'){
    clCheckData[id].status=null;
    btn.style.background='white'; btn.style.borderColor='#ddd'; btn.style.color='#ccc'; btn.textContent='○';
    const nameEl=btn.nextElementSibling;
    if(nameEl){nameEl.style.fontWeight='400';nameEl.style.color='#111';}
  } else {
    clCheckData[id].status='ok';
    btn.style.background='#1D9E75'; btn.style.borderColor='#1D9E75'; btn.style.color='white'; btn.textContent='✓';
    const nameEl=btn.nextElementSibling;
    if(nameEl){nameEl.style.fontWeight='700';nameEl.style.color='#1D9E75';}
  }
  clUpdateAllProgress();
  clUpdateSummary();
}

function clSetStatus(id,status,btn){
  if(!clCheckData[id]) clCheckData[id]={status:null,memo:''};
  if(clCheckData[id].status===status){
    clCheckData[id].status=null;
    const ci=document.getElementById('clci-'+id);
    if(ci) ci.querySelectorAll('.st-b').forEach(b=>b.className='st-b');
  } else {
    clCheckData[id].status=status;
    const ci=document.getElementById('clci-'+id);
    if(ci) ci.querySelectorAll('.st-b').forEach(b=>b.className='st-b');
    btn.classList.add(status);
  }
  clUpdateAllProgress();
  clUpdateSummary();
}

function clSetMemo(id,val){if(!clCheckData[id])clCheckData[id]={status:null,memo:''};clCheckData[id].memo=val;}

function clToggleSec(id){
  const body=document.getElementById('cl-body-'+id);
  const arrow=document.getElementById('cl-arrow-'+id);
  if(!body||!arrow)return;
  if(body.classList.contains('open')){body.classList.remove('open');arrow.classList.remove('open');}
  else{body.classList.add('open');arrow.classList.add('open');}
}

function clUpdateAllProgress(){
  clGetSections().forEach(sec=>{
    const done=sec.items.filter(it=>clCheckData[it.id]?.status).length;
    const el=document.getElementById('cl-prog-'+sec.id);
    if(el) el.textContent=done+'/'+sec.items.length;
  });
}

function clUpdateSummary(){
  let ok=0,repair=0,bad=0,left=0;
  clGetSections().forEach(sec=>sec.items.forEach(it=>{
    const s=clCheckData[it.id]?.status;
    if(s==='ok')ok++;else if(s==='repair')repair++;else if(s==='bad')bad++;else if(!s)left++;
  }));
  const f=(id,v)=>{const e=document.getElementById(id);if(e)e.textContent=v;};
  f('cl-s-ok',ok);f('cl-s-repair',repair);f('cl-s-bad',bad);f('cl-s-left',left);
}

function clInitSigs(){
  ['cl-sig-landlord','cl-sig-tenant'].forEach(id=>{
    const c=document.getElementById(id);if(!c)return;
    const ctx=c.getContext('2d');
    clSigCtx[id]={ctx,drawing:false,last:null};
    ctx.strokeStyle='#111';ctx.lineWidth=2;ctx.lineCap='round';ctx.lineJoin='round';
    const pos=(e)=>{const r=c.getBoundingClientRect();const s=e.touches?e.touches[0]:e;return{x:(s.clientX-r.left)*(c.width/r.width),y:(s.clientY-r.top)*(c.height/r.height)};};
    c.onmousedown=e=>{clSigCtx[id].drawing=true;clSigCtx[id].last=pos(e);};
    c.onmousemove=e=>{if(!clSigCtx[id].drawing)return;const p=pos(e);ctx.beginPath();ctx.moveTo(clSigCtx[id].last.x,clSigCtx[id].last.y);ctx.lineTo(p.x,p.y);ctx.stroke();clSigCtx[id].last=p;};
    c.onmouseup=c.onmouseleave=()=>clSigCtx[id].drawing=false;
    c.ontouchstart=e=>{e.preventDefault();clSigCtx[id].drawing=true;clSigCtx[id].last=pos(e);};
    c.ontouchmove=e=>{e.preventDefault();if(!clSigCtx[id].drawing)return;const p=pos(e);ctx.beginPath();ctx.moveTo(clSigCtx[id].last.x,clSigCtx[id].last.y);ctx.lineTo(p.x,p.y);ctx.stroke();clSigCtx[id].last=p;};
    c.ontouchend=()=>clSigCtx[id].drawing=false;
  });
}

function clClearSig(id){const c=document.getElementById(id);if(c)c.getContext('2d').clearRect(0,0,c.width,c.height);}

function clSaveRecord(){
  const bld=document.getElementById('cl-bld')?.value||'mj';
  const room=document.getElementById('cl-room')?.value||'미입력';
  const name=document.getElementById('cl-name')?.value||'미입력';
  const phone=document.getElementById('cl-phone')?.value||'';
  const date=document.getElementById('cl-date')?.value||new Date().toISOString().split('T')[0];
  const memo=document.getElementById('cl-memo')?.value||'';
  const sigL=document.getElementById('cl-sig-landlord')?.toDataURL()||'';
  const sigT=document.getElementById('cl-sig-tenant')?.toDataURL()||'';
  const snap=JSON.parse(JSON.stringify(clCheckData));
  const record={id:Date.now(),mode:clMode,bld,room,name,phone,date,memo,checkData:snap,sigL,sigT,savedAt:new Date().toLocaleString('ko-KR')};
  clSavedList.unshift(record);
  try{localStorage.setItem('cl_saved_v1',JSON.stringify(clSavedList));}catch(e){}
  const BL={mj:'멋지다',dg:'동광',sj:'십자'};
  showAppAlert('저장 완료!\n\n'+BL[bld]+' '+room+' '+name+'님\n'+(clMode==='in'?'입주 전':'퇴거 후')+' 체크리스트가 저장되었습니다.');
}

function clShowTab(t){
  document.getElementById('cl-view-write').style.display=t==='write'?'block':'none';
  document.getElementById('cl-view-list').style.display=t==='list'?'block':'none';
  document.querySelectorAll('.cl-tab').forEach(b=>b.classList.remove('active'));
  document.getElementById('cltab-'+t).classList.add('active');
  if(t==='list') clRenderSavedList();
}

function clRenderSavedList(){
  const el=document.getElementById('cl-saved-list');
  const empty=document.getElementById('cl-empty');
  if(!el)return;
  if(!clSavedList.length){el.innerHTML='';if(empty)empty.style.display='block';return;}
  if(empty)empty.style.display='none';
  const BL={mj:'멋지다오피스텔',dg:'동광오피스텔',sj:'십자원룸'};
  el.innerHTML=clSavedList.map(r=>{
    const secs=r.mode==='out'?[...CL_SECTIONS,...CL_SECTIONS_OUT_EXTRA]:CL_SECTIONS;
    let ok=0,repair=0,bad=0;
    secs.forEach(sec=>sec.items.forEach(it=>{const s=r.checkData[it.id]?.status;if(s==='ok')ok++;else if(s==='repair')repair++;else if(s==='bad')bad++;}));
    const ml=r.mode==='in'?'입주 전 점검':'퇴거 후 점검';
    const bg=r.mode==='in'?'#E1F5EE':'#FCEBEB',tc=r.mode==='in'?'#0F6E56':'#A32D2D';
    return `<div class="cl-saved-card">
      <div class="cl-sv-header">
        <div class="cl-sv-av" style="background:${bg};color:${tc};">${r.mode==='in'?'🚪':'📦'}</div>
        <div class="cl-sv-info">
          <div class="cl-sv-name">${BL[r.bld]||r.bld} ${r.room} — ${r.name}</div>
          <div class="cl-sv-sub">${ml} · ${r.date} · ${r.savedAt}</div>
          <div style="display:flex;gap:6px;margin-top:4px;">
            <span style="font-size:10px;font-weight:700;color:#1D9E75;">✅${ok}</span>
            <span style="font-size:10px;font-weight:700;color:#E8A020;">🔧${repair}</span>
            <span style="font-size:10px;font-weight:700;color:#E24B4A;">❌${bad}</span>
          </div>
        </div>
        <span class="badge" style="background:${bg};color:${tc};font-size:10px;">${ml}</span>
      </div>
      <div class="cl-sv-btns">
        <button class="cl-sv-btn primary" onclick="clLoadRecord(${r.id})">불러오기</button>
        <button class="cl-sv-btn" onclick="clPrintRecord(${r.id})">🖨 프린트</button>
        <button class="cl-sv-btn danger" onclick="clDeleteRecord(${r.id})">삭제</button>
      </div>
    </div>`;
  }).join('');
}

function clLoadRecord(id){
  const r=clSavedList.find(x=>x.id===id);if(!r)return;
  clMode=r.mode;
  clCheckData=JSON.parse(JSON.stringify(r.checkData));
  clSetMode(r.mode);
  const f=(eid,val)=>{const e=document.getElementById(eid);if(e)e.value=val;};
  f('cl-bld',r.bld);f('cl-room',r.room);f('cl-name',r.name);f('cl-phone',r.phone||'');f('cl-date',r.date);f('cl-memo',r.memo||'');
  // 버튼 상태 복원
  clGetSections().forEach(sec=>sec.items.forEach(it=>{
    const s=clCheckData[it.id]?.status;if(!s)return;
    const ci=document.getElementById('clci-'+it.id);
    if(ci){
      const ta=ci.querySelector('.cli-memo');if(ta&&clCheckData[it.id]?.memo)ta.value=clCheckData[it.id].memo;
      ci.querySelectorAll('.st-b').forEach(b=>{
        if(b.textContent.includes('정상')&&s==='ok')b.classList.add('ok');
        else if(b.textContent.includes('수리')&&s==='repair')b.classList.add('repair');
        else if(b.textContent.includes('불량')&&s==='bad')b.classList.add('bad');
        else if(b.textContent.includes('해당없음')&&s==='na')b.classList.add('na');
      });
    }
  }));
  clUpdateSummary();
  clShowTab('write');
}

function clDeleteRecord(id){
  showAppConfirm('체크리스트를 삭제하시겠습니까?',()=>{
    clSavedList=clSavedList.filter(x=>x.id!==id);
    try{localStorage.setItem('cl_saved_v1',JSON.stringify(clSavedList));}catch(e){}
    clRenderSavedList();
  });
}

function clDoPrint(){
  const BL={mj:'멋지다오피스텔',dg:'동광오피스텔',sj:'십자원룸'};
  const bld=BL[document.getElementById('cl-bld')?.value||'mj']||'';
  const room=document.getElementById('cl-room')?.value||'';
  const name=document.getElementById('cl-name')?.value||'';
  const date=document.getElementById('cl-date')?.value||'';
  const memo=document.getElementById('cl-memo')?.value||'';
  const ml=clMode==='in'?'입주 전 점검표':'퇴거 후 점검표';
  const secs=clGetSections();
  const sigL=document.getElementById('cl-sig-landlord')?.toDataURL()||'';
  const sigT=document.getElementById('cl-sig-tenant')?.toDataURL()||'';
  let totalOk=0,totalAll=0;
  secs.forEach(sec=>sec.items.forEach(it=>{totalAll++;if(clCheckData[it.id]?.status==='ok')totalOk++;}));

  // 항목 행 생성 - 2컬럼 레이아웃
  let allItems=[];
  secs.forEach(sec=>sec.items.forEach(it=>allItems.push({sec:sec.title,name:it.name,id:it.id})));
  let rows='';
  for(let i=0;i<allItems.length;i+=2){
    const a=allItems[i], b=allItems[i+1];
    const aOk=clCheckData[a.id]?.status==='ok', aMemo=clCheckData[a.id]?.memo||'';
    const bOk=b&&clCheckData[b.id]?.status==='ok', bMemo=b?clCheckData[b.id]?.memo||'':``;
    rows+=`<tr>
      <td style="font-size:12px;font-weight:600;">${a.name}</td>
      <td style="text-align:center;font-size:14px;font-weight:700;color:${aOk?'#1D9E75':'#ddd'};">${aOk?'✓':'○'}</td>
      <td style="font-size:11px;color:#555;">${aMemo}</td>
      ${b?`<td style="font-size:12px;font-weight:600;border-left:2px solid #e0e0e0;">${b.name}</td>
      <td style="text-align:center;font-size:14px;font-weight:700;color:${bOk?'#1D9E75':'#ddd'};">${bOk?'✓':'○'}</td>
      <td style="font-size:11px;color:#555;">${bMemo}</td>`:'<td colspan="3" style="border-left:2px solid #e0e0e0;background:#fafafa;"></td>'}
    </tr>`;
  }

  const sigLimg=sigL&&sigL!=='data:,'?`<img src="${sigL}" style="width:100%;height:40px;object-fit:contain;">`:'<div style="height:40px;"></div>';
  const sigTimg=sigT&&sigT!=='data:,'?`<img src="${sigT}" style="width:100%;height:40px;object-fit:contain;">`:'<div style="height:40px;"></div>';

  const h=`<!DOCTYPE html><html lang="ko"><head><meta charset="UTF-8"><title>${ml}</title>
  <style>
  @page{size:A4 portrait;margin:10mm 13mm 10mm 13mm;}
  *{box-sizing:border-box;margin:0;padding:0;}
  html,body{width:210mm;font-family:'Malgun Gothic','Apple SD Gothic Neo',sans-serif;font-size:14px;color:#111;-webkit-print-color-adjust:exact;print-color-adjust:exact;}
  h2{text-align:center;font-size:20px;font-weight:700;letter-spacing:4px;margin-bottom:10px;padding-bottom:8px;border-bottom:2.5px solid #111;}
  .info-t{width:100%;border-collapse:collapse;margin-bottom:10px;}
  .info-t td{border:1px solid #999;padding:6px 9px;font-size:13px;}
  .info-t .lbl{background:#f0f0f0;font-weight:700;width:65px;text-align:center;}
  .items-t{width:100%;border-collapse:collapse;margin-bottom:10px;}
  .items-t th{background:#185FA5;color:white;padding:7px 9px;font-size:13px;font-weight:700;text-align:center;border:1px solid #185FA5;}
  .items-t td{border:1px solid #ccc;padding:7px 8px;vertical-align:middle;font-size:13px;}
  .items-t tr:nth-child(even){background:#f9f9f9;}
  .memo-box{border:1px solid #ccc;padding:7px 9px;font-size:13px;min-height:35px;line-height:1.7;margin-bottom:10px;border-radius:3px;}
  .sig-wrap{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:10px;}
  .sig-box{border:1px solid #999;border-radius:4px;padding:7px 9px;}
  .sig-lbl{font-size:13px;font-weight:700;color:#555;margin-bottom:5px;}
  .sig-img-area{border:1px dashed #ccc;height:50px;border-radius:3px;overflow:hidden;}
  .progress{background:#E6F1FB;border-radius:4px;padding:7px 12px;margin-bottom:10px;font-size:13px;display:flex;gap:16px;align-items:center;}
  </style></head><body>
  <h2>${ml}</h2>
  <table class="info-t">
    <tr><td class="lbl">건물·호실</td><td><b>${bld} ${room}</b></td><td class="lbl">세입자</td><td><b>${name}</b></td></tr>
    <tr><td class="lbl">${clMode==='in'?'입주일':'퇴거일'}</td><td>${date}</td><td class="lbl">작성일</td><td>${new Date().toLocaleDateString('ko-KR')}</td></tr>
  </table>
  <div class="progress">
    <span>정상 체크: <b style="color:#1D9E75;font-size:14px;">${totalOk}</b> / ${totalAll}항목</span>
    <span style="color:#888;font-size:11px;">○ = 미확인 &nbsp; ✓ = 정상</span>
  </div>
  <table class="items-t">
    <thead><tr>
      <th style="width:23%;">항목</th><th style="width:8%;">상태</th><th style="width:18%;">메모</th>
      <th style="width:23%;border-left:2px solid #0d4a8f;">항목</th><th style="width:8%;">상태</th><th style="width:18%;">메모</th>
    </tr></thead>
    <tbody>${rows}</tbody>
  </table>
  ${memo?`<div style="font-size:11px;font-weight:700;margin-bottom:3px;">특이사항</div><div class="memo-box">${memo.replace(/\n/g,'<br>')}</div>`:''}
  <div class="sig-wrap">
    <div class="sig-box"><div class="sig-lbl">임대인 서명</div><div class="sig-img-area">${sigLimg}</div></div>
    <div class="sig-box"><div class="sig-lbl">${clMode==='in'?'세입자(입주자)':'세입자(퇴거자)'} 서명</div><div class="sig-img-area">${sigTimg}</div></div>
  </div>
  <div style="margin-top:6px;text-align:center;font-size:9px;color:#aaa;">목포 임대 관리 시스템 · ${new Date().toLocaleString('ko-KR')}</div>
  </body></html>`;
  printHTML(h, '체크리스트');
}

function clPrintRecord(id){
  const r=clSavedList.find(x=>x.id===id);if(!r)return;
  const prev={mode:clMode,data:JSON.parse(JSON.stringify(clCheckData))};
  clMode=r.mode;clCheckData=JSON.parse(JSON.stringify(r.checkData));
  const f=(eid,val)=>{const e=document.getElementById(eid);if(e)e.value=val;};
  f('cl-bld',r.bld);f('cl-room',r.room);f('cl-name',r.name);f('cl-date',r.date);f('cl-memo',r.memo||'');
  clDoPrint();
  setTimeout(()=>{clMode=prev.mode;clCheckData=prev.data;},1000);
}
