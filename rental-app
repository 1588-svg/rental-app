function submitReg(){
  var name=(document.getElementById('reg-name')||{}).value;
  name = name ? name.trim() : '';
  if(!name){ showAppAlert('이름을 입력해주세요.'); return; }

  // 월세: reg-rent-man (만원단위) 우선, 없으면 reg-rent
  var rentManEl = document.getElementById('reg-rent-man');
  var rentEl = document.getElementById('reg-rent');
  var rentMan = rentManEl ? parseInt(rentManEl.value||0) : 0;
  var rent = rentMan>0 ? rentMan*10000 : parseInt((rentEl||{}).value||0);
  if(!rent){ showAppAlert('월세를 입력해주세요.\n(만원 단위로 숫자 입력)'); return; }

  // 보증금
  var depManEl = document.getElementById('reg-deposit-man');
  var depEl = document.getElementById('reg-deposit');
  var depMan = depManEl ? parseInt(depManEl.value||0) : 0;
  var deposit = depMan>0 ? depMan*10000 : parseInt((depEl||{}).value||0);

  // 기타 정보
  var phone = (document.getElementById('reg-phone')||{}).value||'';
  var rn = (document.getElementById('reg-rn')||{}).value||'';
  var addr = (document.getElementById('reg-addr')||{}).value||'';
  var biz = (document.getElementById('reg-biz')||{}).value||'';
  var startDate = (document.getElementById('reg-start')||{}).value||'';
  var endDate = (document.getElementById('reg-end')||{}).value||'';
  var payDay = (regPayday||1)+'일';
  var clean = regCleanSel ? [...regCleanSel].join(', ')||'미선택' : '미선택';
  var opts = regOptSel ? [...regOptSel].join(', ')||'없음' : '없음';
  var bldName = {mj:'멋지다오피스텔',dg:'동광오피스텔',sj:'십자원룸'}[regBld]||regBld;

  // 상태 결정
  var status = 'active';
  if(endDate){
    var daysLeft = Math.ceil((new Date(endDate)-new Date())/864e5);
    if(daysLeft<=60) status='expiring';
  }

  // 새 세입자 객체 생성
  var maxId = TENANTS.reduce(function(m,t){ return Math.max(m, parseInt(t.id)||0); }, 0);
  var newId = maxId+1;
  var colors = ['#E6F1FB','#EAF3DE','#FBEAF0','#FAEEDA','#E1F5EE','#EEEDFE'];
  var tcs = ['#0C447C','#27500A','#72243E','#633806','#085041','#3C3489'];
  var ci = newId % colors.length;

  var newTenant = {
    id: newId,
    bld: regBld,
    room: regRoom+'호',
    name: name,
    phone: phone,
    rent: rent,
    deposit: deposit,
    start: startDate,
    end: endDate,
    status: status,
    overdue: 0,
    color: colors[ci],
    tc: tcs[ci],
    rn: rn,
    addr: addr,
    biz: biz,
    payDay: payDay
  };

  // 기존 동일 호실 공실 제거 후 추가
  var existIdx = TENANTS.findIndex(function(t){ return t.bld===regBld && t.room===regRoom+'호'; });
  if(existIdx>=0) TENANTS.splice(existIdx,1);
  TENANTS.push(newTenant);

  saveSharedData();
  showAppAlert('등록 완료!\n\n'+name+'님\n'+bldName+' '+regFloor+'층 '+regRoom+'호\n월세: '+(rent/10000)+'만원\n보증금: '+(deposit/10000)+'만원\n납부일: 매월 '+payDay);
  goBack();
}
