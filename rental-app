let _editManualKey='';
function editManual(key){
  if(USERS[curUser]?.role!=='boss'){showAppAlert('사장님만 수정할 수 있습니다.');return;}
  _editManualKey=key;
  renderManualEditPopup();
}

function renderManualEditPopup(){
  const key=_editManualKey;
  const m=MANUALS[key];
  document.getElementById('manual-edit-popup')?.remove();
  const popup=document.createElement('div');
  popup.id='manual-edit-popup';
  popup.style.cssText='position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.6);z-index:9999;overflow-y:auto;padding:16px;';
  let stepsHtml=m.steps.map((s,i)=>`
    <div style="background:#f8f8f8;border-radius:10px;padding:10px;margin-bottom:8px;position:relative;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
        <span style="font-size:11px;color:#888;font-weight:700;">${i+1}번</span>
        <button onclick="delManualStep(${i})" style="padding:3px 9px;border-radius:6px;border:1px solid #E24B4A;background:white;color:#E24B4A;cursor:pointer;font-size:11px;font-weight:700;font-family:inherit;">삭제</button>
      </div>
      <input type="text" value="${s.t.replace(/"/g,'&quot;')}" placeholder="제목" id="med-t-${i}"
        style="width:100%;padding:8px;border-radius:6px;border:1px solid #ddd;font-size:13px;font-family:inherit;margin-bottom:5px;">
      <textarea id="med-d-${i}" style="width:100%;padding:8px;border-radius:6px;border:1px solid #ddd;font-size:12px;font-family:inherit;min-height:55px;resize:vertical;">${s.d}</textarea>
    </div>`).join('');
  popup.innerHTML=`<div style="background:white;border-radius:16px;padding:20px;max-width:520px;margin:0 auto;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
      <div style="font-size:15px;font-weight:700;">${m.title}</div>
      <button onclick="document.getElementById('manual-edit-popup').remove()" style="padding:6px 12px;border-radius:8px;border:1px solid #ddd;background:white;cursor:pointer;font-size:12px;font-family:inherit;">닫기</button>
    </div>
    <div id="med-steps">${stepsHtml}</div>
    <button onclick="addManualStep()" style="width:100%;padding:10px;border-radius:10px;border:1.5px dashed #185FA5;background:white;color:#185FA5;cursor:pointer;font-size:13px;font-weight:700;font-family:inherit;margin-bottom:10px;">+ 항목 추가</button>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
      <button onclick="document.getElementById('manual-edit-popup').remove()" style="padding:12px;border-radius:10px;border:1px solid #ddd;background:white;cursor:pointer;font-size:13px;font-weight:700;font-family:inherit;">취소</button>
      <button onclick="saveManual()" style="padding:12px;border-radius:10px;border:none;background:#185FA5;color:white;cursor:pointer;font-size:13px;font-weight:700;font-family:inherit;">저장</button>
    </div>
  </div>`;
  document.body.appendChild(popup);
}

function addManualStep(){
  const key=_editManualKey;
  MANUALS[key].steps.push({t:'새 항목',d:'내용을 입력하세요.'});
  renderManualEditPopup();
}

function delManualStep(idx){
  const key=_editManualKey;
  if(MANUALS[key].steps.length<=1){showAppAlert('최소 1개 항목이 있어야 합니다.');return;}
  MANUALS[key].steps.splice(idx,1);
  renderManualEditPopup();
}

function saveManual(){
  const key=_editManualKey;
  const count=MANUALS[key].steps.length;
  for(let i=0;i<count;i++){
    const t=document.getElementById('med-t-'+i)?.value||'';
    const d=document.getElementById('med-d-'+i)?.value||'';
    if(t) MANUALS[key].steps[i].t=t;
    if(d) MANUALS[key].steps[i].d=d;
  }
  document.getElementById('manual-edit-popup')?.remove();
  openManual(key);
  showAppAlert('저장되었습니다.');
}

