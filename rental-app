      <div style="text-align:right;flex-shrink:0;">${rightLabel}</div>
    </div>`;
  }).join('') + '</div>';
}

function printPaySummary(){
  const today = new Date();
  const ym = today.getFullYear()+'-'+pad(today.getMonth()+1);
  const bldName={mj:'멋지다오피스텔',dg:'동광오피스텔',sj:'십자원룸'};
  let allUnpaid=0;
  const bldRows = ['mj','dg','sj'].map(bld=>{
    const list=TENANTS.filter(t=>t.bld===bld&&t.status!=='vacant');
    const unpaid=list.reduce((s,t)=>s+calcRealUnpaid(t),0);
    allUnpaid+=unpaid;
    return `<tr><td style="font-weight:700;">${bldName[bld]}</td><td style="color:${unpaid>0?'#E24B4A':'#1D9E75'};font-weight:700;">${unpaid>0?unpaid.toLocaleString()+'원':'없음'}</td><td>${list.filter(t=>(t.overdue||0)>0).length}명</td></tr>`;
  }).join('');

  const tenantRows = TENANTS.filter(t=>t.status!=='vacant'&&(payListBld==='all'||t.bld===payListBld))
    .sort((a,b)=>(b.overdue||0)-(a.overdue||0))
    .map(t=>{
      const entries=(PAY_DATA[t.id]&&PAY_DATA[t.id][ym])||[];
      const paid=entries.reduce((s,r)=>s+r.amt,0);
      const unpaid=calcRealUnpaid(t);
      const statusLabel=unpaid>0?'체납':paid>=t.rent?'납부완료':'미납부';
      const statusColor=unpaid>0?'#E24B4A':paid>=t.rent?'#1D9E75':'#E8A020';
      return `<tr>
        <td style="font-weight:700;">${bldName[t.bld]||t.bld}</td>
        <td>${t.room}</td><td>${t.name}</td>
        <td style="text-align:right;">${t.rent.toLocaleString()}원</td>
        <td style="text-align:right;color:${unpaid>0?'#E24B4A':'#1D9E75'};font-weight:700;">${unpaid>0?'-'+unpaid.toLocaleString()+'원':'0원'}</td>
        <td style="text-align:center;font-weight:700;color:${statusColor};">${statusLabel}</td>
      </tr>`;
    }).join('');

  const h=`<!DOCTYPE html><html lang="ko"><head><meta charset="UTF-8"><title>미납 현황</title>
  <style>
  ${A4_CSS}
  h2{font-size:18px;font-weight:700;margin-bottom:5px;}
  .sub{font-size:11px;color:#666;margin-bottom:14px;padding-bottom:8px;border-bottom:2px solid #111;}
  .total{background:#FCEBEB;border-radius:8px;padding:12px 16px;margin-bottom:14px;display:flex;justify-content:space-between;align-items:center;}
  .total.ok{background:#EAF3DE;}
  .total-n{font-size:24px;font-weight:700;color:#E24B4A;}
  .total.ok .total-n{color:#1D9E75;}
  table{width:100%;border-collapse:collapse;font-size:11px;margin-bottom:14px;}
  th{background:#f0f0f0;padding:7px 8px;font-weight:700;border:1px solid #bbb;text-align:center;}
  td{border:1px solid #ccc;padding:6px 8px;vertical-align:middle;}
  </style></head><body>
  <h2>미납 현황 보고서</h2>
  <div class="sub">기준일: ${today.toLocaleDateString('ko-KR')} &nbsp;|&nbsp; ${ym.replace('-','년 ')}월 &nbsp;|&nbsp; 목포 임대 관리 시스템</div>
  <div class="total${allUnpaid===0?' ok':''}">
    <div><div style="font-size:12px;color:#666;font-weight:600;">전체 미납금액</div><div class="total-n">${allUnpaid>0?allUnpaid.toLocaleString()+'원':'없음 ✅'}</div></div>
    <div style="font-size:32px;">${allUnpaid>0?'🔴':'✅'}</div>
  </div>
  <table>
    <thead><tr><th>건물</th><th>미납금액</th><th>체납 세입자 수</th></tr></thead>
    <tbody>${bldRows}</tbody>
  </table>
  <table>
    <thead><tr><th>건물</th><th>호실</th><th>이름</th><th>월세</th><th>미납액</th><th>상태</th></tr></thead>
    <tbody>${tenantRows}</tbody>
  </table>
  <div style="margin-top:10px;text-align:right;font-size:9px;color:#aaa;">출력일: ${new Date().toLocaleString('ko-KR')}</div>
  </body></html>`;
  printHTML(h,'미납현황');
}

