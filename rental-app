// 설정 방법: 건물관리 → 계정 설정 → Google Sheets 연동
let SCRIPT_URL = localStorage.getItem('gsheet_url') || '';
const SYNC_KEY = 'rental_shared_data_v1';
let syncTimer = null;
let isSyncing = false;
let lastSyncTime = null;

// ── 상태 표시 ──
function showSyncStatus(msg, color){
  const el = document.getElementById('sync-status-bar');
  if(!el) return;
  el.textContent = msg;
  el.style.background = color==='ok'?'#EAF3DE':color==='err'?'#FCEBEB':'#FAEEDA';
  el.style.color = color==='ok'?'#2d6b11':color==='err'?'#A32D2D':'#7a4200';
  el.style.display = 'block';
  if(color==='ok') setTimeout(()=>{ if(el.textContent===msg) el.style.display='none'; }, 3000);
}

// ── 서버에 저장 ──
async function saveSharedData(){
  const now = new Date();
  const data = {
    TENANTS: TENANTS, COMPLAINTS: COMPLAINTS, MEMOS: MEMOS,
    PAY_DATA: PAY_DATA, contracts: contracts, tenantOptions: tenantOptions, tenantContracts: tenantContracts,
    lastSaved: now.toISOString(), savedBy: curUser || 'unknown'
  };
  // 로컬 저장 먼저 (항상)
  localSave();

  if(!SCRIPT_URL) return;
  try {
    showSyncStatus('⏳ 공유 저장 중...', 'wait');
    const jsonStr = JSON.stringify(data);
    const ctrl = new AbortController();
    const timer = setTimeout(()=>ctrl.abort(), 20000);
    // GET 방식 - 구글 스크립트에서 가장 안정적
    const url = SCRIPT_URL + '?action=save&data=' + encodeURIComponent(jsonStr);
    const res = await fetch(url, {method:'GET', mode:'cors', signal:ctrl.signal});
    clearTimeout(timer);
    const result = await res.json();
    if(result.ok){
      lastSyncTime = new Date();
      showSyncStatus('✅ 공유 저장 완료 · ' + lastSyncTime.toLocaleTimeString('ko-KR'), 'ok');
    } else {
      showSyncStatus('⚠ 서버 오류: '+(result.error||''), 'err');
    }
  } catch(e){
