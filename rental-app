function saveMemo(){
  const body=document.getElementById('memo-body').value.trim();
  if(!body){alert('메모 내용을 입력해주세요.');return;}
  if(!mEditTid){alert('호실을 선택해주세요.');return;}
  const d=new Date().toISOString().split('T')[0];
  if(mEditId){const m=MEMOS.find(x=>x.id===mEditId);if(m){m.body=body;m.tag=mSelTag;m.date=d;}}
  else MEMOS.unshift({id:mNextId++,tid:mEditTid,tag:mSelTag,body,date:d,pinned:false});
  goBack();
  saveSharedData();
}

