  const dl=Math.ceil((new Date(newEnd)-new Date())/864e5);
  if(dl>60) t.status='active';
  else if(dl>0) t.status='expiring';
  // 수납 월 목록 연장
  const months=[];
  if(t.start!=='-'){
    let d=new Date(t.start);const end=new Date(newEnd);const now=new Date();
    while(d<=now&&d<=end){months.push(d.getFullYear()+'-'+pad(d.getMonth()+1));d.setMonth(d.getMonth()+1);}
  }
  if(months.length) payMonths=months;
  document.getElementById('contract-extend-popup').remove();
  updateContractInfo(tid);
  renderPayLedger();
  renderTenants();
  refreshDashStats();
  saveSharedData();
  showAppAlert('계약 연장 완료!\n\n'+t.name+'님\n기존 종료일: '+oldEnd+'\n새 종료일: '+newEnd+'\n\n수납 내역도 자동으로 연장되었습니다.');
