  const targets=TENANTS.filter(t=>smsSelIds.has(t.id));
  alert(`✅ ${targets.length}명에게 발송 완료!\n\n`+targets.slice(0,5).map(t=>t.name+' '+t.room).join('\n')+(targets.length>5?`\n...외 ${targets.length-5}명`:''));
