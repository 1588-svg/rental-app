function saveContractFn(){
  const signed = sigData.tenant != null;
  const tenantName = document.getElementById('c-te-name').value || '(미입력)';
  const tenantPhone = document.getElementById('c-te-phone').value || '';
  const rentVal = document.getElementById('c-rent-v').textContent;
  const startDate = document.getElementById('sy-v')?.textContent + ' ' + document.getElementById('sm-v')?.textContent + ' ' + document.getElementById('sd-v')?.textContent;
  const endDate = document.getElementById('ey-v')?.textContent + ' ' + document.getElementById('em-v')?.textContent + ' ' + document.getElementById('ed-v')?.textContent;

  // 계약서 HTML 캡처 (이미지로 변환용)
  const paperEl = document.getElementById('contract-paper');
  let contractHtml = paperEl ? paperEl.innerHTML : '';
  // 드롭다운 숨기기
  contractHtml = contractHtml.replace(/class="sf-drop[^"]*"/g, 'style="display:none"');

  // 서명 데이터 포함한 계약서 썸네일 생성
  const contractImgData = generateContractThumbnail();

  const contractRecord = {
    id: Date.now(),
    tenant: tenantName,
    phone: tenantPhone,
    bld: cBldKey,
    floor: cFloor,
    room: cRoom,
    rent: rentVal,
    date: new Date().toLocaleDateString('ko-KR'),
    signed,
    ownerSig: sigData.owner || '',
    tenantSig: sigData.tenant || '',
    contractHtml,
    contractImg: contractImgData, // 썸네일 이미지
    startDate,
    endDate
  };
  contracts.unshift(contractRecord);

  // 해당 세입자(호실 기준) 상세정보 > 계약서 사진란에 자동 반영
  const bldKey = {멋지다오피스텔:'mj', 동광오피스텔:'dg', 십자원룸:'sj'}[cBldKey] || 'mj';
  const roomStr = cRoom + '호';
  const matchTenant = TENANTS.find(t => t.bld === bldKey && t.room === roomStr);
  if(matchTenant){
    // tenantContracts에 계약서 저장
    if(!tenantContracts[matchTenant.id]) tenantContracts[matchTenant.id] = [];
    tenantContracts[matchTenant.id].unshift(contractRecord);
  }

  if(window._contractSavedCallback){ window._contractSavedCallback(); window._contractSavedCallback=null; }
  const bldLblSave = {멋지다오피스텔:'멋지다', 동광오피스텔:'동광', 십자원룸:'십자'}[cBldKey]||cBldKey;
  showAppAlert('저장 완료!\n\n' + bldLblSave + ' ' + cRoom + '호 ' + tenantName + '님\n계약서가 상세정보 계약서 사진란에 저장되었습니다.');
  saveSharedData();
  // 납입현황 상세정보 화면 열려있으면 즉시 갱신
  if(matchTenant && curPayTid === matchTenant.id){
    setTimeout(()=>updateDetailOptions(matchTenant.id), 100);
  }
  goBack();
}

// 계약서 썸네일 생성 (canvas)
function generateContractThumbnail(){
  try {
    const canvas = document.createElement('canvas');
    canvas.width = 400; canvas.height = 566; // A4 비율
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = 'white';
    ctx.fillRect(0, 0, 400, 566);
    ctx.fillStyle = '#111';
    ctx.font = 'bold 16px Malgun Gothic, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('부동산 임대차 계약서', 200, 30);
    ctx.beginPath(); ctx.moveTo(10, 40); ctx.lineTo(390, 40); ctx.lineWidth=2; ctx.strokeStyle='#111'; ctx.stroke();
    ctx.font = '12px Malgun Gothic, sans-serif';
    ctx.textAlign = 'left';
    const bldV = document.getElementById('c-bld-v')?.textContent || '';
    const flV = document.getElementById('c-fl-v')?.textContent || '';
    const rmV = document.getElementById('c-rm-v')?.textContent || '';
    const rentV = document.getElementById('c-rent-v')?.textContent || '';
    const owName = document.getElementById('c-ow-name')?.value || '';
    const teName = document.getElementById('c-te-name')?.value || '';
    ctx.fillText('소재지: ' + bldV, 14, 65);
    ctx.fillText('호실: ' + flV + ' ' + rmV, 14, 85);
    ctx.fillText('월세: ' + rentV, 14, 105);
    ctx.fillText('임대인: ' + owName, 14, 125);
    ctx.fillText('임차인: ' + teName, 14, 145);
    ctx.fillText('계약일: ' + new Date().toLocaleDateString('ko-KR'), 14, 165);
    // 서명 그리기
    if(sigData.owner){
      const img1 = new Image(); img1.src = sigData.owner;
      ctx.drawImage(img1, 20, 480, 160, 50);
      ctx.strokeStyle='#ccc'; ctx.lineWidth=1; ctx.strokeRect(20,475,160,55);
      ctx.fillStyle='#888'; ctx.font='9px sans-serif'; ctx.fillText('임대인 서명',20,473);
    }
    if(sigData.tenant){
      const img2 = new Image(); img2.src = sigData.tenant;
      ctx.drawImage(img2, 220, 480, 160, 50);
      ctx.strokeStyle='#ccc'; ctx.lineWidth=1; ctx.strokeRect(220,475,160,55);
      ctx.fillStyle='#888'; ctx.font='9px sans-serif'; ctx.fillText('임차인 서명',220,473);
    }
    // 워터마크
    ctx.fillStyle='rgba(0,0,0,0.06)'; ctx.font='bold 28px sans-serif'; ctx.textAlign='center';
    ctx.save(); ctx.translate(200,300); ctx.rotate(-0.4); ctx.fillText('목포 임대관리', 0, 0); ctx.restore();
    return canvas.toDataURL('image/jpeg', 0.85);
  } catch(e){ return ''; }
}
