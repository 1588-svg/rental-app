}
function clearRoomFilterAndBack(){
  cRoomFilter=null;
  goBack();
}
function selCBld(b,el){cBldF=b;document.querySelectorAll('#s-complaint .bld-tab').forEach(t=>t.classList.remove('active'));el.classList.add('active');renderComplaints();}
function selCF(f,el){cStatusF=f;document.querySelectorAll('#s-complaint .filter-bar .fb').forEach(b=>b.classList.remove('active'));el.classList.add('active');renderComplaints();}
function renderComplaints(){
  const list=COMPLAINTS.filter(c=>{
    const bOk=cBldF==='all'||c.bld===cBldF;
    const sOk=cStatusF==='all'||c.status===cStatusF;
    const rOk=!cRoomFilter||(c.room===cRoomFilter);
    return bOk&&sOk&&rOk;
  });
  const el=document.getElementById('complaint-list');
  if(!list.length){el.innerHTML='<div class="empty">민원이 없습니다.</div>';return;}
  // 호실 필터 배너 업데이트
  const banner=document.getElementById('room-filter-banner');
  const titleEl=document.getElementById('complaint-screen-title');
  if(cRoomFilter){
    if(banner){banner.style.display='flex';document.getElementById('room-filter-label').textContent='📍 '+cRoomFilter+' 민원만 보기';}
    if(titleEl) titleEl.textContent=cRoomFilter+' 민원';
  } else {
    if(banner) banner.style.display='none';
    if(titleEl) titleEl.textContent='민원 관리';
  }
  const slbl={new:'신규접수',prog:'처리중',done:'처리완료',hold:'보류'};
  const sbg={new:'#FCEBEB',prog:'#FAEEDA',done:'#EAF3DE',hold:'#F1EFE8'};
  const stc={new:'#A32D2D',prog:'#7a4200',done:'#2d6b11',hold:'#444'};
  const pcol={긴급:'#A32D2D',높음:'#E8A020',보통:'#185FA5',낮음:'#1D9E75'};
  el.innerHTML=list.map(c=>{
    const dl=Math.ceil((new Date(c.due)-new Date())/864e5);
    const dStr=dl<0?`<span style="color:#A32D2D;font-weight:700;">기한 ${Math.abs(dl)}일 초과</span>`:`<span style="color:${dl<=1?'#E8A020':'#555'};">${dl}일 남음</span>`;
    const urgBar=c.pri==='긴급'?`<div class="cc-urgent-bar">⚠ 긴급 민원 — 즉시 처리 필요</div>`:'';
    let btns='';
    if(c.status==='new')btns=`<div class="cc-btns"><button class="cc-btn primary" onclick="chCS(${c.id},'prog')">처리시작</button><button class="cc-btn" onclick="openEditComplaint(${c.id})">수정</button><button class="cc-btn warning" onclick="chCS(${c.id},'hold')">보류</button><button class="cc-btn" style="color:#A32D2D;border-color:#F09595;" onclick="delComplaint(${c.id})">삭제</button></div>`;
    else if(c.status==='prog')btns=`<div class="cc-btns"><button class="cc-btn success" onclick="chCS(${c.id},'done')">처리완료</button><button class="cc-btn" onclick="openEditComplaint(${c.id})">수정</button><button class="cc-btn" style="color:#A32D2D;border-color:#F09595;" onclick="delComplaint(${c.id})">삭제</button></div>`;
    else if(c.status==='done')btns=`<div class="cc-btns"><button class="cc-btn" onclick="chCS(${c.id},'new')">재접수</button><button class="cc-btn" onclick="openEditComplaint(${c.id})">수정</button><button class="cc-btn" style="color:#A32D2D;" onclick="delComplaint(${c.id})">삭제</button></div>`;
    else btns=`<div class="cc-btns"><button class="cc-btn primary" onclick="chCS(${c.id},'new')">접수재개</button><button class="cc-btn" style="color:#A32D2D;" onclick="delComplaint(${c.id})">삭제</button></div>`;
    return `<div class="complaint-card${c.pri==='긴급'?' urgent':''}">
      ${urgBar}
      <div class="cc-top">
        <div class="cc-cat-icon" style="background:${CAT_BG[c.cat]||'#F1EFE8'};">${CAT_ICONS[c.cat]||'🔧'}</div>
        <div class="cc-body"><div class="cc-title">${c.cat} <span style="font-size:10px;color:#999;font-weight:400;">· ${BLD_LBL[c.bld]} ${c.room} · ${c.name}</span></div><div class="cc-sub">${c.date} · 담당: ${c.worker}</div></div>
        <span class="badge" style="background:${sbg[c.status]};color:${stc[c.status]};">${slbl[c.status]}</span>
      </div>
      <div class="cc-desc">${c.desc}</div>
      <div class="cc-detail-row">
        <div><span style="font-size:10px;color:#aaa;">우선순위</span><br><span style="font-weight:700;color:${pcol[c.pri]||'#333'};">${c.pri}</span></div>
        <div><span style="font-size:10px;color:#aaa;">처리 기한</span><br>${dStr}</div>
      </div>
      ${btns}
    </div>`;
  }).join('');
}
