function buildMemoTagRow(){
  document.getElementById('memo-tag-row').innerHTML=MEMO_TAGS.map(t=>`<button style="padding:6px 12px;border-radius:20px;border:1px solid ${t.id===mSelTag?t.tc:'#ddd'};background:${t.id===mSelTag?t.bg:'white'};color:${t.id===mSelTag?t.tc:'#555'};cursor:pointer;font-size:12px;font-weight:600;font-family:inherit;" onclick="selMTag('${t.id}',this,'${t.bg}','${t.tc}')">${t.label}</button>`).join('');
