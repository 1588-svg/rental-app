let sigDrawing=false,sigLast=null,bigCtx=null;
function openSigPopup(target){
  sigTarget=target;
  document.getElementById('sig-popup-title').textContent=target==='owner'?'임대인 서명':'임차인 서명';
  const bg=document.getElementById('sig-popup-bg');bg.classList.add('open');
  const canvas=document.getElementById('sig-big-canvas');
  bigCtx=canvas.getContext('2d');bigCtx.clearRect(0,0,canvas.width,canvas.height);
  bigCtx.strokeStyle='#111';bigCtx.lineWidth=2.5;bigCtx.lineCap='round';bigCtx.lineJoin='round';
  const pos=(e,c)=>{const r=c.getBoundingClientRect();const s=e.touches?e.touches[0]:e;return{x:(s.clientX-r.left)*(c.width/r.width),y:(s.clientY-r.top)*(c.height/r.height)};};
  canvas.onmousedown=e=>{sigDrawing=true;sigLast=pos(e,canvas);};
  canvas.onmousemove=e=>{if(!sigDrawing)return;const p=pos(e,canvas);bigCtx.beginPath();bigCtx.moveTo(sigLast.x,sigLast.y);bigCtx.lineTo(p.x,p.y);bigCtx.stroke();sigLast=p;};
  canvas.onmouseup=canvas.onmouseleave=()=>sigDrawing=false;
  canvas.ontouchstart=e=>{e.preventDefault();sigDrawing=true;sigLast=pos(e,canvas);};
  canvas.ontouchmove=e=>{e.preventDefault();if(!sigDrawing)return;const p=pos(e,canvas);bigCtx.beginPath();bigCtx.moveTo(sigLast.x,sigLast.y);bigCtx.lineTo(p.x,p.y);bigCtx.stroke();sigLast=p;};
  canvas.ontouchend=()=>sigDrawing=false;
}
function clearBigSig(){if(bigCtx){const c=document.getElementById('sig-big-canvas');bigCtx.clearRect(0,0,c.width,c.height);}}
function closeSigPopup(){document.getElementById('sig-popup-bg').classList.remove('open');}
function confirmSig(){
  const c=document.getElementById('sig-big-canvas');
  const hasData=c.getContext('2d').getImageData(0,0,c.width,c.height).data.some(x=>x!==0);
  if(!hasData){alert('서명을 해주세요.');return;}
  sigData[sigTarget]=c.toDataURL();
  // 썸네일에 그리기
  const pv=document.getElementById(`${sigTarget}-sig-preview`);
  const pvCtx=pv.getContext('2d');pvCtx.clearRect(0,0,pv.width,pv.height);
  const img=new Image();img.onload=()=>pvCtx.drawImage(img,0,0,pv.width,pv.height);img.src=sigData[sigTarget];
  pv.style.display='block';
  document.getElementById(`${sigTarget}-sig-label`).style.display='none';
  document.getElementById(`${sigTarget}-sig-thumb`).classList.add('has-sig');
  closeSigPopup();
}
function clearSigThumb(target){
  sigData[target]=null;
  const pv=document.getElementById(`${target}-sig-preview`);pv.style.display='none';pv.getContext('2d').clearRect(0,0,pv.width,pv.height);
  document.getElementById(`${target}-sig-label`).style.display='inline';
  document.getElementById(`${target}-sig-thumb`).classList.remove('has-sig');
}

