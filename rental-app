function syncInBackground(){
  if(!SCRIPT_URL || !curUser) return;
  showSyncStatus('⏳ 동기화 중...', 'wait');
  var xhr = new XMLHttpRequest();
  xhr.timeout = 7000;
  xhr.open('GET', SCRIPT_URL+'?action=load', true);
  xhr.onload = function(){
    try {
      var json = JSON.parse(xhr.responseText);
      if(json.ok && json.data){
        // 서버 vs 로컬 시간 비교
        var localRaw = localStorage.getItem(SYNC_KEY);
        var localTime = localRaw ? new Date(JSON.parse(localRaw).lastSaved||0) : new Date(0);
        var serverTime = new Date(json.data.lastSaved||0);
        if(serverTime > localTime){
          // 서버가 최신 → 적용
          applyData(json.data);
          lastSyncTime = new Date();
          showSyncStatus('✅ 서버 동기화 완료', 'ok');
          var active = document.querySelector('.screen.active');
          if(active) _showScreen(active.id);
        } else {
          // 로컬이 최신 → 서버에 업로드
          showSyncStatus('✅ 로컬 최신 데이터', 'ok');
          saveSharedData();
        }
      } else {
        // 서버에 데이터 없음 → 로컬 데이터를 서버에 업로드
        saveSharedData();
        showSyncStatus('✅ 로컬 데이터 서버 업로드 완료', 'ok');
      }
    } catch(e){
      showSyncStatus('⚠ 서버 연결 실패', 'err');
    }
  };
  xhr.ontimeout = function(){ showSyncStatus('⚠ 서버 응답 없음', 'err'); };
  xhr.onerror = function(){ showSyncStatus('⚠ 오프라인', 'err'); };
  try { xhr.send(); } catch(e){}
}

