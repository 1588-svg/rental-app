// ══ 입력 자동 포맷 ══
function formatPhone(el){
  let v=el.value.replace(/[^0-9]/g,'');
  if(!v.startsWith('010')) v='010'+v.replace(/^010/,'');
  if(v.length>11) v=v.slice(0,11);
  if(v.length<=3) el.value=v;
  else if(v.length<=7) el.value=v.slice(0,3)+'-'+v.slice(3);
  else el.value=v.slice(0,3)+'-'+v.slice(3,7)+'-'+v.slice(7);
  // 커서 끝으로
  setTimeout(()=>{ el.selectionStart=el.selectionEnd=el.value.length; },0);
}

function formatRN(el){
  let v=el.value.replace(/[^0-9]/g,'');
  if(v.length>13) v=v.slice(0,13);
  if(v.length<=6) el.value=v;
  else el.value=v.slice(0,6)+'-'+v.slice(6);
  setTimeout(()=>{ el.selectionStart=el.selectionEnd=el.value.length; },0);
}

function formatBiz(el){
  let v=el.value.replace(/[^0-9]/g,'');
  if(v.length>10) v=v.slice(0,10);
  if(v.length<=3) el.value=v;
  else if(v.length<=5) el.value=v.slice(0,3)+'-'+v.slice(3);
  else el.value=v.slice(0,3)+'-'+v.slice(3,5)+'-'+v.slice(5);
  setTimeout(()=>{ el.selectionStart=el.selectionEnd=el.value.length; },0);
}


