// PAY_DATA 기반으로 모든 세입자 status/overdue 재계산
function syncAllTenantStatus(){
  var today = new Date();
  var todayYm = today.getFullYear()+'-'+pad(today.getMonth()+1);
  TENANTS.forEach(function(t){
    if(t.status==='vacant' || !t.start || t.start==='-') return;
    // 총 청구 vs 총 납부
    var totalCharge=0, totalPaid=0;
    var d=new Date(t.start);
    // 계약 종료 후에도 퇴거 전까지 청구
    while(true){
      var ym=d.getFullYear()+'-'+pad(d.getMonth()+1);
      if(ym>todayYm) break;
      totalCharge+=t.rent;
      var entries=(PAY_DATA[t.id]&&PAY_DATA[t.id][ym])||[];
      totalPaid+=entries.reduce(function(s,r){return s+r.amt;},0);
      d.setMonth(d.getMonth()+1);
    }
    var unpaid=Math.max(0, totalCharge-totalPaid);
    t.overdue=unpaid;
    // 상태 결정
    var daysToEnd=t.end&&t.end!=='-'?Math.ceil((new Date(t.end)-today)/864e5):9999;
    if(unpaid>0){
      t.status='overdue';
      t.color='#FCEBEB'; t.tc='#791F1F';
    } else if(daysToEnd>=0 && daysToEnd<=60){
      t.status='expiring';
      t.color='#FAEEDA'; t.tc='#633806';
    } else if(daysToEnd<0){
      t.status='expired';
    } else {
      t.status='active';
      // 색상 복원 (기존 색상 유지)
      if(t.color==='#FCEBEB') t.color='#EAF3DE';
      if(t.tc==='#791F1F') t.tc='#27500A';
    }
  });
}


