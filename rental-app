function addPayEntry(){
  if(!curPayTid)return;
  const date=document.getElementById('pay-date').value;
  if(curPayAmt<=0){alert('금액을 선택해주세요.');return;}
  if(!date){alert('날짜를 입력해주세요.');return;}
  const note=document.getElementById('pay-note').value;
  const ym=date.slice(0,7);
  if(!PAY_DATA[curPayTid])PAY_DATA[curPayTid]={};
  if(!PAY_DATA[curPayTid][ym])PAY_DATA[curPayTid][ym]=[];
  PAY_DATA[curPayTid][ym].push({date,amt:curPayAmt,note});
  PAY_DATA[curPayTid][ym].sort((a,b)=>a.date.localeCompare(b.date));
  if(!payMonths.includes(ym))payMonths.push(ym);
  resetQuick();
  document.getElementById('pay-note').value='';
  // 상태 동기화 후 화면 갱신
  syncAllTenantStatus();
  renderPayLedger();
  // 로컬 저장 (단순하게 한번만)
  localSave();
}

