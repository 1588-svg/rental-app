// ── PAY_DATA 기반 실제 미납금 계산 (다중납부 정확 처리) ──
function calcRealUnpaid(t){
  if(!t || t.status==='vacant') return 0;
  if(!t.start || t.start==='-') return 0;
  var today = new Date();
  var todayYm = today.getFullYear()+'-'+pad(today.getMonth()+1);
  var totalCharge = 0;
  var totalPaid = 0;
  var d = new Date(t.start);
  // ★ 계약 종료 후에도 퇴거 전까지 (오늘까지) 청구
  // endDate 조건 제거 - 오늘까지만 체크
  while(true){
    var ym = d.getFullYear()+'-'+pad(d.getMonth()+1);
    if(ym > todayYm) break;
    totalCharge += t.rent;
    var entries = (PAY_DATA[t.id]&&PAY_DATA[t.id][ym])||[];
    totalPaid += entries.reduce(function(s,r){ return s+r.amt; }, 0);
    d.setMonth(d.getMonth()+1);
  }
  return Math.max(0, totalCharge - totalPaid);
}

