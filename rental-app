    <div style="font-size:13px;color:#555;margin-bottom:16px;line-height:1.7;">퇴거 처리하면 공실로 전환됩니다.<br>퇴거 이력은 복구 목록에 저장됩니다.</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
      <button onclick="document.getElementById('evict-popup-bg').remove()" style="padding:12px;border-radius:10px;border:1px solid #ddd;background:white;cursor:pointer;font-size:14px;font-weight:700;font-family:inherit;">취소</button>
      <button onclick="confirmEvict(${tid})" style="padding:12px;border-radius:10px;border:none;background:#E24B4A;color:white;cursor:pointer;font-size:14px;font-weight:700;font-family:inherit;">퇴거 확인</button>
    </div>
  </div>`;
  document.body.appendChild(popup);
}

function confirmEvict(tid){
  const t = TENANTS.find(x=>x.id===tid);
  if(!t) return;

  // 이력 저장 (20년 보관 - localStorage)
  const history = loadEvictHistory();
  const record = {
    ...JSON.parse(JSON.stringify(t)),
    evictedAt: new Date().toISOString(),
    evictedAtDisplay: new Date().toLocaleString('ko-KR'),
    evictedBy: curUser||'unknown',
    contractData: tenantContracts[tid]||[],
    payData: PAY_DATA[tid]||{}
  };
  history.unshift(record);
  saveEvictHistory(history);

  // 메모리 복구용 백업
  evictedTenants.unshift(record);

  // 공실 처리
  t.status = 'vacant';
  t.name = '공실';
  t.phone = '-';
  t.overdue = 0;
  t.color = '#F1EFE8';
  t.tc = '#888';

  document.getElementById('evict-popup-bg')?.remove();
  saveSharedData();
  renderTenants();
  refreshDashStats();

  showEvictUndoToast(tid);
}

function showEvictUndoToast(tid){
  const existing = document.getElementById('evict-toast');
  if(existing) existing.remove();

  const toast = document.createElement('div');
  toast.id = 'evict-toast';
  toast.style.cssText = 'position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:#333;color:white;border-radius:12px;padding:12px 16px;font-size:13px;z-index:9998;display:flex;align-items:center;gap:12px;box-shadow:0 4px 16px rgba(0,0,0,0.3);max-width:320px;width:90%;';
  toast.innerHTML = '퇴거 처리 완료 <button onclick="undoEvict('+tid+')" style="padding:5px 12px;border-radius:8px;border:none;background:#1D9E75;color:white;cursor:pointer;font-size:12px;font-weight:700;font-family:inherit;white-space:nowrap;">복구</button>';
  document.body.appendChild(toast);
  // 10초 후 자동 사라짐
  setTimeout(()=>toast.remove(), 10000);
}

function undoEvict(tid){
  const backup = evictedTenants.find(x=>x.id===tid);
  if(!backup){ alert('복구 데이터가 없습니다.'); return; }

  const t = TENANTS.find(x=>x.id===tid);
  if(!t){ alert('세입자 데이터를 찾을 수 없습니다.'); return; }

  // 원래 데이터로 복구
  Object.assign(t, backup);
  delete t.evictedAt;
  delete t.evictedBy;

  document.getElementById('evict-toast')?.remove();
  saveSharedData();
  renderTenants();
  refreshDashStats();
