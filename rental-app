// 계약서 폼 초기화 함수
function contractFormReset(){
  var today = new Date();
  var y = today.getFullYear();
  var m = today.getMonth()+1;
  var d = today.getDate();
  var yStr = y+'년';
  var mStr = m+'월';
  var dStr = d+'일';

  // 보증금 초기화
  var depHidden = document.getElementById('c-dep-v');
  if(depHidden) depHidden.value='없음(0원)';
  var depDirect = document.getElementById('c-dep-direct');
  if(depDirect) depDirect.value='';

  // 월세 초기화
  var rentV = document.getElementById('c-rent-v');
  if(rentV) rentV.textContent='30만원';

  // 계약금/잔금 초기화
  var camt = document.getElementById('c-camt');
  if(camt) camt.value='';
  var bal = document.getElementById('c-bal');
  if(bal) bal.value='';

  // 임차인 정보 초기화
  ['c-te-name','c-te-phone','c-te-addr','c-te-rn'].forEach(function(id){
    var el=document.getElementById(id); if(el) el.value='';
  });

  // 비고 초기화
  var note = document.getElementById('c-note');
  if(note) note.value='';

  // 인도날(시작일) = 오늘
  var sy=document.getElementById('sy-v'), sm=document.getElementById('sm-v'), sd=document.getElementById('sd-v');
  if(sy) sy.textContent=yStr;
  if(sm) sm.textContent=mStr;
  if(sd) sd.textContent=dStr;

  // 잔금일도 오늘
  var by=document.getElementById('by-v'), bm=document.getElementById('bm-v'), bd=document.getElementById('bd-v');
  if(by) by.textContent=yStr;
  if(bm) bm.textContent=mStr;
  if(bd) bd.textContent=dStr;

  // 종료일 = 오늘 + 12개월 (기본)
  var endDate = new Date(today);
  endDate.setMonth(endDate.getMonth()+12);
  // 하루 빼기 (예: 4월18일 시작 → 익년 4월17일 종료)
  endDate.setDate(endDate.getDate()-1);
  var ey=document.getElementById('ey-v'), em=document.getElementById('em-v'), ed=document.getElementById('ed-v');
  if(ey) ey.textContent=endDate.getFullYear()+'년';
  if(em) em.textContent=(endDate.getMonth()+1)+'월';
  if(ed) ed.textContent=endDate.getDate()+'일';

  // 서명일 = 오늘
  var sigy=document.getElementById('sigy-v'), sigm=document.getElementById('sigm-v'), sigd=document.getElementById('sigd-v');
  if(sigy) sigy.textContent=yStr;
  if(sigm) sigm.textContent=mStr;
  if(sigd) sigd.textContent=dStr;

  // 기간 초기화
  var pv=document.getElementById('period-v');
  if(pv) pv.value='12개월';

  // ★ 임대인 정보 자동 입력 (현재 선택된 건물 기준)
  var owner = OWNERS[cBldKey] || OWNERS['멋지다오피스텔'];
  var owName=document.getElementById('c-ow-name');
  var owAddr=document.getElementById('c-ow-addr');
  var owRn=document.getElementById('c-ow-rn');
  var owPhone=document.getElementById('c-ow-phone');
  if(owName) owName.value=owner.name;
  if(owAddr) owAddr.value=owner.addr;
  if(owRn) owRn.value=owner.rn;
  if(owPhone) owPhone.value=owner.phone;
}

// 제4조 기간 변경 시 종료일 자동 계산
function onPeriodChange(){
  var pv=document.getElementById('period-v');
  if(!pv) return;
  var val=(pv.value||'12개월').trim();
  // 숫자 추출
  var months=0, days=0;
  var mMatch=val.match(/(\d+)\s*개월/);
  var dMatch=val.match(/(\d+)\s*일/);
  if(mMatch) months=parseInt(mMatch[1]);
  if(dMatch) days=parseInt(dMatch[1]);
  if(months===0 && days===0) return;

  // 시작일 읽기
  var sy=document.getElementById('sy-v'), sm=document.getElementById('sm-v'), sd=document.getElementById('sd-v');
  if(!sy||!sm||!sd) return;
  var startY=parseInt(sy.textContent)||new Date().getFullYear();
  var startM=parseInt(sm.textContent)||new Date().getMonth()+1;
  var startD=parseInt(sd.textContent)||new Date().getDate();

  var start = new Date(startY, startM-1, startD);
  var end = new Date(start);
  if(months>0) end.setMonth(end.getMonth()+months);
  if(days>0) end.setDate(end.getDate()+days);
  end.setDate(end.getDate()-1); // 하루 빼기

  var ey=document.getElementById('ey-v'), em=document.getElementById('em-v'), edEl=document.getElementById('ed-v');
  if(ey) ey.textContent=end.getFullYear()+'년';
  if(em) em.textContent=(end.getMonth()+1)+'월';
  if(edEl) edEl.textContent=end.getDate()+'일';
}
