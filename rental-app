function isPast(ym){
  var now=new Date();
  var nowYm=now.getFullYear()+'-'+pad(now.getMonth()+1);
  return ym<=nowYm;
}
function getPayStatus(ym,tid){
  const rent=TENANTS.find(x=>x.id===parseInt(tid))?.rent||0;
  const entries=(PAY_DATA[tid]&&PAY_DATA[tid][ym])||[];
  const paid=entries.reduce((s,r)=>s+r.amt,0);
  if(!isPast(ym))return 'wait';
  if(paid===0)return 'overdue';
  if(paid>=rent)return 'paid';
  return 'partial';
}
function renderPayLedger(){
  if(!curPayTid)return;
  const t=TENANTS.find(x=>x.id===curPayTid);if(!t)return;
  const rent=t.rent;
  const slbl={paid:'납부완료',partial:'일부납부',overdue:'연체',wait:'대기'};
  const sbg={paid:'#EAF3DE',partial:'#FAEEDA',overdue:'#FCEBEB',wait:'#f5f5f5'};
  const stc={paid:'#2d6b11',partial:'#7a4200',overdue:'#A32D2D',wait:'#888'};

  // ── 총 청구 / 총 납부 계산 (다중납부 정확 처리) ──
  let totalCharge=0, totalPaid=0;
  payMonths.forEach(ym=>{
    if(isPast(ym)) totalCharge += rent;
    const entries=(PAY_DATA[curPayTid]&&PAY_DATA[curPayTid][ym])||[];
    totalPaid += entries.reduce((s,r)=>s+r.amt,0);
  });
  const realUnpaid = Math.max(0, totalCharge - totalPaid);

  // ── 월별 표 렌더 ──
  let rows='';
  payMonths.forEach(ym=>{
    const [y,m]=ym.split('-');
    const label=y.slice(2)+'년 '+parseInt(m)+'월';
    const entries=(PAY_DATA[curPayTid]&&PAY_DATA[curPayTid][ym])||[];
    const paidThisMonth=entries.reduce((s,r)=>s+r.amt,0);
    const past=isPast(ym);
    // 이 달 미납 = 이달 청구 - 이달 납부 (단순)
    const thisMonthUnpaid = past ? Math.max(0, rent - paidThisMonth) : 0;
    // 상태
    let st='wait';
    if(!past) st='wait';
    else if(paidThisMonth>=rent) st='paid';
    else if(paidThisMonth>0) st='partial';
    else st='overdue';
    // 미납 셀
    const uCell = !past ? '<span style="color:#bbb;">—</span>'
      : paidThisMonth>=rent
        ? '<span style="color:#1D9E75;">납부완료</span>'
        : '<span class="u-amt">'+thisMonthUnpaid.toLocaleString()+'</span>';
    if(!entries.length){
      rows+=`<tr>
        <td class="left">${label}</td>
        <td style="color:#bbb;">—</td><td style="color:#bbb;">—</td>
        <td>${uCell}</td>
        <td><span class="st-pill" style="background:${sbg[st]};color:${stc[st]};">${slbl[st]}</span></td>
        <td></td></tr>`;
    } else {
      entries.forEach((e,i)=>{
        rows+=`<tr>
          <td class="left">${i===0?label:''}</td>
          <td style="font-size:11px;">${e.date}</td>
          <td class="p-amt">${e.amt.toLocaleString()}</td>
          <td>${i===entries.length-1?uCell:''}</td>
          <td>${i===entries.length-1?`<span class="st-pill" style="background:${sbg[st]};color:${stc[st]};">${slbl[st]}</span>`:''}</td>
          <td><button style="padding:2px 7px;border:1px solid #ddd;border-radius:5px;background:white;cursor:pointer;font-size:10px;color:#888;" onclick="delPayEntry('${ym}',${i})">삭제</button></td></tr>`;
      });
    }
  });

  document.getElementById('pay-tbody').innerHTML=rows||'<tr><td colspan="6" style="text-align:center;color:#bbb;padding:20px;">납부 내역이 없습니다.</td></tr>';
  document.getElementById('pay-tfoot').innerHTML=`<tr class="tfoot-row"><td class="left">합계</td><td></td><td class="p-amt">${totalPaid.toLocaleString()}</td><td class="u-amt">${realUnpaid>0?realUnpaid.toLocaleString():'0'}</td><td colspan="2"></td></tr>`;
  // 상단 3개 숫자
  document.getElementById('p-total').textContent=totalCharge.toLocaleString();
  document.getElementById('p-paid').textContent=totalPaid.toLocaleString();
  document.getElementById('p-unpaid').textContent=realUnpaid.toLocaleString();
}
