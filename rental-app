function printHTML(htmlContent, title){
  // 전체화면 오버레이 미리보기 (srcdoc 방식 - 로컬파일도 작동)
  let overlay = document.getElementById('print-overlay');
  if(overlay) overlay.remove();

  // 인쇄 내용 전역 저장 (doPrintFrame에서 사용)
  window._printContent = htmlContent;
  window._printTitle = title;

  overlay = document.createElement('div');
  overlay.id = 'print-overlay';
  overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:#555;z-index:99999;display:flex;flex-direction:column;';

  overlay.innerHTML =
    '<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 16px;background:#185FA5;color:white;flex-shrink:0;">'
    +'<span style="font-size:14px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:55%;">'+title+'</span>'
    +'<div style="display:flex;gap:6px;flex-shrink:0;">'
    +'<button onclick="doPrintFrame()" style="padding:8px 14px;border-radius:8px;border:none;background:white;color:#185FA5;cursor:pointer;font-size:13px;font-weight:700;font-family:inherit;">인쇄 / PDF저장</button>'
    +'<button onclick="closePrintOverlay()" style="padding:8px 12px;border-radius:8px;border:1px solid rgba(255,255,255,.4);background:transparent;color:white;cursor:pointer;font-size:13px;font-weight:700;font-family:inherit;">✕ 닫기</button>'
    +'</div></div>'
    +'<div style="flex:1;overflow:auto;display:flex;justify-content:center;padding:16px;">'
    +'<iframe id="print-iframe-main" style="width:210mm;min-height:297mm;border:none;background:white;box-shadow:0 4px 20px rgba(0,0,0,.3);" srcdoc=""></iframe>'
    +'</div>';

  document.body.appendChild(overlay);

  // srcdoc으로 내용 삽입 (로컬 파일에서도 작동)
  setTimeout(()=>{
    const iframe = document.getElementById('print-iframe-main');
    if(iframe) iframe.srcdoc = htmlContent;
  }, 50);
}

function realPrint(iframeId){
  const iframe = document.getElementById(iframeId);
  if(!iframe){ alert('인쇄할 내용이 없습니다.'); return; }
  try {
    iframe.contentWindow.focus();
    iframe.contentWindow.print();
  } catch(e) {
    // 폴백: 새 탭
    const doc = iframe.contentDocument || iframe.contentWindow.document;
    const w = window.open('','_blank');
    if(w){ w.document.write(doc.documentElement.outerHTML); w.document.close(); setTimeout(()=>w.print(),800); }
    else { alert('팝업을 허용해 주세요. 브라우저 주소창 오른쪽 팝업 차단 아이콘 클릭'); }
  }
}

function doPrintFrame(){
  // 방법1: iframe 직접 인쇄 (폰)
  const iframe = document.getElementById('print-iframe-main');
  if(iframe && iframe.contentDocument && iframe.contentDocument.body){
    try{
      iframe.contentWindow.focus();
      iframe.contentWindow.print();
      return;
    }catch(e){}
  }
  // 방법2: 새 창에서 인쇄 (PC)
  const content = window._printContent;
  if(content){
    const w = window.open('','_blank','width=900,height=700');
    if(w){
      w.document.write(content);
      w.document.close();
      w.onload = ()=>{ w.focus(); w.print(); };
      setTimeout(()=>{ try{w.focus();w.print();}catch(e){} }, 800);
      return;
    }
  }
  alert('인쇄를 시작할 수 없습니다.\nCtrl+P (PC) 또는 공유 메뉴에서 인쇄를 선택하세요.');
}
