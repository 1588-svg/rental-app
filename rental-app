      t.statusType==='expiring' ?
      `<div style="font-size:11px;color:#7a4200;margin-top:2px;">계약 종료: ${t.end}</div>` : '';
    return `<div style="display:flex;align-items:center;gap:10px;padding:12px 14px;border-bottom:1px solid #f5f5f5;cursor:pointer;background:${t.statusType==='unpaid'?'#FFFAFA':'white'};" onclick="${onclick}">
