function copyPhone(phone){
  if(navigator.clipboard){
    navigator.clipboard.writeText(phone).then(function(){
      showSyncStatus('번호 복사됨: '+phone, 'ok');
    });
  } else {
    // 구형 방식
    var ta=document.createElement('textarea');
    ta.value=phone; ta.style.position='fixed'; ta.style.opacity='0';
    document.body.appendChild(ta); ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    showSyncStatus('번호 복사됨: '+phone, 'ok');
  }
}

function doCall(phone){
  closePhonePopup();
  // 클립보드에 번호 복사 후 안내
  var copied = false;
  if(navigator.clipboard){
    navigator.clipboard.writeText(phone).then(function(){
      showSyncStatus('📋 '+phone+' 복사됨 → 전화앱에서 붙여넣기', 'ok');
    }).catch(function(){});
    copied = true;
  } else {
    try {
      var ta=document.createElement('textarea');
      ta.value=phone; ta.style.cssText='position:fixed;opacity:0;top:0;left:0;';
      document.body.appendChild(ta); ta.focus(); ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      copied = true;
    } catch(e){}
  }
  // 전화 앱 실행 시도 (여러 방식)
  setTimeout(function(){
    try { window.location.href='tel:'+phone; } catch(e){}
  }, 100);
}

function doSmsOpen(phone, smsBody){
  closePhonePopup();
  // 문자 내용 클립보드 복사
  var textToCopy = smsBody || phone;
  if(navigator.clipboard){
    navigator.clipboard.writeText(textToCopy).then(function(){
      if(smsBody) showSyncStatus('📋 문자내용 복사됨 → 문자앱에서 붙여넣기', 'ok');
    }).catch(function(){});
  }
  // 문자 앱 실행 시도
  setTimeout(function(){
    var url = smsBody ? 'sms:'+phone+'?body='+encodeURIComponent(smsBody) : 'sms:'+phone;
    try { window.location.href=url; } catch(e){}
  }, 100);
}

