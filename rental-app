// ── 서버에서 불러오기 ──
async function loadSharedData(){
  if(!SCRIPT_URL){
    loadLocalData();
    return true;
  }
  try {
    showSyncStatus('⏳ 데이터 불러오는 중...', 'wait');
    const ctrl = new AbortController();
    const timer = setTimeout(()=>ctrl.abort(), 7000);
    const res = await fetch(SCRIPT_URL+'?action=load', {method:'GET', mode:'cors', signal:ctrl.signal});
    clearTimeout(timer);
    const json = await res.json();
    if(json.ok && json.data){
      // 서버 데이터가 로컬보다 최신이면 적용
      const localRaw = localStorage.getItem(SYNC_KEY);
      const localTime = localRaw ? new Date(JSON.parse(localRaw).lastSaved||0) : new Date(0);
      const serverTime = new Date(json.data.lastSaved||0);
      if(serverTime > localTime){
        applyData(json.data);
        showSyncStatus('✅ 서버 데이터 로드 완료', 'ok');
      } else {
        loadLocalData();
        showSyncStatus('✅ 로컬 데이터 사용 중', 'ok');
      }
      return true;
    } else {
      loadLocalData();
      showSyncStatus('📂 로컬 데이터 사용 중', 'ok');
    }
  } catch(e){
    loadLocalData();
    showSyncStatus('⚠ 서버 연결 실패 · 로컬 사용', 'err');
  }
  // 로컬 폴백
  try {
    const raw = localStorage.getItem(SYNC_KEY);
    if(!raw) return false;
    applyData(JSON.parse(raw));
    return true;
  } catch(e){ return false; }
}

function applyData(data){
  if(data.TENANTS && data.TENANTS.length>0){
    TENANTS.length=0; data.TENANTS.forEach(t=>TENANTS.push(t));
  }
  if(data.COMPLAINTS){ COMPLAINTS.length=0; data.COMPLAINTS.forEach(c=>COMPLAINTS.push(c)); }
  if(data.MEMOS){ MEMOS.length=0; data.MEMOS.forEach(m=>MEMOS.push(m)); }
  if(data.PAY_DATA) Object.assign(PAY_DATA, data.PAY_DATA);
  if(data.contracts){ contracts.length=0; data.contracts.forEach(c=>contracts.push(c)); }
  if(data.tenantContracts) Object.assign(tenantContracts, data.tenantContracts);
  if(data.tenantOptions){
    Object.keys(data.tenantOptions).forEach(function(k){
      var v=data.tenantOptions[k];
      tenantOptions[k] = (v instanceof Set) ? v : new Set(Array.isArray(v)?v:['냉장고','에어컨','전자도어락']);
    });
  }
  // 데이터 불러온 후 즉시 상태 동기화
  try { syncAllTenantStatus(); } catch(e){}
}

// ── 자동 동기화 (60초마다 로컬→서버 업로드만) ──
function autoSync(){
  clearTimeout(syncTimer);
  syncTimer = setTimeout(async ()=>{
    if(SCRIPT_URL && !isSyncing && curUser){
      isSyncing=true;
      try {
        // 서버에서 최신 데이터 확인
        var xhr = new XMLHttpRequest();
        xhr.timeout = 6000;
        xhr.open('GET', SCRIPT_URL+'?action=load', true);
        xhr.onload = function(){
          try {
            var json = JSON.parse(xhr.responseText);
            if(json.ok && json.data){
              var localRaw = localStorage.getItem(SYNC_KEY);
              var localTime = localRaw ? new Date(JSON.parse(localRaw).lastSaved||0) : new Date(0);
              var serverTime = new Date(json.data.lastSaved||0);
              if(serverTime > localTime){
                // 서버가 최신 → 즉시 반영
                applyData(json.data);
                localSave();
                syncAllTenantStatus();
                // 현재 화면 즉시 갱신
                var active = document.querySelector('.screen.active');
                if(active){
                  if(active.id==='s-tenant') renderTenants();
                  else if(active.id==='s-payment') renderPayLedger();
                  else if(active.id==='s-pay-list') renderPayList();
                  else if(active.id==='s-complaint') renderComplaints();
                  else if(active.id==='s-memo') renderMemos();
                  else if(active.id==='s-dash') initDash();
                }
                showSyncStatus('🔄 업데이트됨 · ' + new Date().toLocaleTimeString('ko-KR'), 'ok');
              }
            }
          } catch(e){}
          isSyncing=false;
          autoSync();
        };
        xhr.ontimeout = function(){ isSyncing=false; autoSync(); };
        xhr.onerror = function(){ isSyncing=false; autoSync(); };
        xhr.send();
      } catch(e){ isSyncing=false; autoSync(); }
    } else {
      autoSync();
    }
  }, 5000); // 5초마다 체크
}

// ── 실제 데이터 기반 통계 계산 ──
function calcStats(bldFilter){
  const today = new Date();
  const soonDays = 90;
  let over=0, vac=0, exp=0, totalRent=0, totalPaid=0, totalUnpaid=0;
  const ym = today.getFullYear()+'-'+pad(today.getMonth()+1);

  // 전체 관리 호실 수 계산 (ALL_ROOMS 기반 — 등록된 세입자 + 미등록 공실 모두 포함)
  const blds = bldFilter==='all' ? ['mj','dg','sj'] : [bldFilter];
  blds.forEach(bld=>{
    const rooms = ALL_ROOMS[bld] || [];
    rooms.forEach(room=>{
      const t = TENANTS.find(x=>x.bld===bld && x.room===room+'호');
      if(!t || t.status==='vacant'){
        // 공실 (미등록 포함)
        vac++;
      } else {
        // 입주 중인 세입자
        if(t.status==='overdue') over++;
        if(t.end && t.end!=='-'){
          const dl = Math.ceil((new Date(t.end)-today)/864e5);
          if(dl<=soonDays) exp++;
        }
        totalRent += t.rent;
        const entries = (PAY_DATA[t.id] && PAY_DATA[t.id][ym]) || [];
        const paid = entries.reduce((s,r)=>s+r.amt,0);
        totalPaid += paid;
        totalUnpaid += Math.max(0, t.rent - paid);
      }
    });
  });
  return {over, vac, exp, totalRent, totalPaid, totalUnpaid};
}

