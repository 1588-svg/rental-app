  var callBtn = document.getElementById('pp-call-btn');
  var smsBtn = document.getElementById('pp-sms-btn');
  if(callBtn) callBtn.onclick = function(){ doCall(phone); };
  if(smsBtn) smsBtn.onclick = function(){ doSmsOpen(phone, smsBody); };
