function setContractPeriod(months){
  const startEl = document.getElementById('reg-start');
  const endEl = document.getElementById('reg-end');
  if(!startEl||!endEl) return;
  const start = new Date(startEl.value || new Date());
  const end = new Date(start);
  end.setMonth(end.getMonth()+months);
  endEl.value = end.getFullYear()+'-'+String(end.getMonth()+1).padStart(2,'0')+'-'+String(end.getDate()).padStart(2,'0');
  // 버튼 활성화 표시
  const months2period = {1:'1개월',3:'3개월',6:'6개월',12:'1년 ✓',24:'2년'};
  const btns = document.querySelectorAll('#reg-form-content button[onclick^="setContractPeriod"]');
  btns.forEach(b=>{
    const m = parseInt(b.getAttribute('onclick').match(/\d+/)[0]);
    if(m===months){
      b.style.border='1.5px solid #185FA5';b.style.background='#E6F1FB';b.style.color='#0C447C';
    } else {
      b.style.border='1px solid #ddd';b.style.background='white';b.style.color='#555';
    }
  });
}

