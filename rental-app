<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>임대 관리 시스템</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Malgun Gothic','Apple SD Gothic Neo',sans-serif;background:#f0f2f5;min-height:100vh;font-size:13px;}
.screen{display:none;max-width:520px;margin:0 auto;padding:10px 10px 80px;}
.screen.active{display:block;}

/* 공통 */
.topbar{display:flex;align-items:center;gap:8px;margin-bottom:12px;background:white;border-radius:12px;padding:10px 14px;border:1px solid #e8e8e8;}
.back-btn{width:34px;height:34px;border-radius:8px;border:1px solid #ddd;background:#f8f8f8;cursor:pointer;font-size:17px;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:#333;}
.back-btn:active{background:#eee;}
.topbar-title{font-size:16px;font-weight:700;color:#111;flex:1;}
.card{background:white;border:1px solid #e8e8e8;border-radius:12px;padding:14px;margin-bottom:10px;}
.btn{padding:10px 16px;border-radius:8px;border:none;cursor:pointer;font-size:13px;font-weight:600;transition:all .15s;font-family:inherit;}
.btn:active{transform:scale(.97);}
.btn-primary{background:#185FA5;color:white;}
.btn-success{background:#1D9E75;color:white;}
.btn-danger{background:#E24B4A;color:white;}
.btn-outline{background:white;border:1px solid #ddd;color:#444;}
.btn-block{width:100%;padding:12px;}
.field{margin-bottom:10px;}
.field label{display:block;font-size:11px;color:#777;margin-bottom:3px;font-weight:600;}
.field input,.field select,.field textarea{width:100%;padding:9px 12px;border-radius:8px;border:1px solid #ddd;font-size:13px;color:#111;outline:none;font-family:inherit;background:white;}
.field input:focus,.field select:focus,.field textarea:focus{border-color:#185FA5;box-shadow:0 0 0 2px rgba(24,95,165,.1);}
.field textarea{min-height:70px;resize:vertical;}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.field-row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;}
.badge{display:inline-block;padding:3px 8px;border-radius:20px;font-size:11px;font-weight:600;}
.b-red{background:#FCEBEB;color:#A32D2D;}
.b-orange{background:#FAEEDA;color:#7a4200;}
.b-green{background:#EAF3DE;color:#2d6b11;}
.b-blue{background:#E6F1FB;color:#0C447C;}
.b-gray{background:#F1EFE8;color:#444;}
.empty{text-align:center;padding:40px 20px;color:#aaa;font-size:13px;}
.section-title{font-size:12px;font-weight:700;color:#888;margin-bottom:8px;text-transform:uppercase;letter-spacing:.5px;}

/* 바텀 네비 */
.bottom-nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:520px;background:white;border-top:1px solid #e8e8e8;display:grid;grid-template-columns:repeat(4,1fr);padding:6px 8px;gap:4px;z-index:100;}
.nav-btn{display:flex;flex-direction:column;align-items:center;gap:2px;padding:6px 4px;border-radius:8px;cursor:pointer;border:none;background:transparent;font-family:inherit;}
.nav-btn:active{background:#f5f5f5;}
.nav-btn.active{background:#EBF4FF;}
.nav-icon{font-size:20px;line-height:1;}
.nav-lbl{font-size:10px;color:#888;font-weight:600;}
.nav-btn.active .nav-lbl{color:#185FA5;}

/* 로그인 */
#s-login{padding:40px 16px;}
.login-box{max-width:320px;margin:0 auto;background:white;border-radius:20px;border:1px solid #e8e8e8;padding:32px 26px;}
.login-logo{width:60px;height:60px;background:linear-gradient(135deg,#E24B4A,#c93333);border-radius:18px;display:flex;align-items:center;justify-content:center;color:white;font-size:28px;font-weight:700;margin:0 auto 16px;box-shadow:0 4px 16px rgba(226,75,74,.3);}
.login-title{text-align:center;font-size:20px;font-weight:700;color:#111;margin-bottom:4px;}
.login-sub{text-align:center;font-size:12px;color:#999;margin-bottom:24px;}
.login-err{color:#E24B4A;font-size:12px;text-align:center;margin-top:8px;min-height:18px;}
.quick-login{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-top:16px;padding-top:14px;border-top:1px solid #f0f0f0;}
.ql{padding:9px 4px;border-radius:10px;border:1px solid #e8e8e8;background:#fafafa;cursor:pointer;font-size:10px;color:#666;text-align:center;line-height:1.7;}
.ql:active{background:#E6F1FB;}

/* 대시보드 헤더 */
.dash-header{background:white;border-radius:14px;padding:12px 14px;margin-bottom:10px;border:1px solid #e8e8e8;}
.dash-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.app-logo{width:36px;height:36px;background:linear-gradient(135deg,#E24B4A,#c93333);border-radius:10px;display:flex;align-items:center;justify-content:center;color:white;font-size:17px;font-weight:700;flex-shrink:0;}
.bld-tabs{display:grid;grid-template-columns:repeat(4,1fr);gap:5px;}
.bld-tab{padding:8px 4px;border-radius:8px;border:1px solid #ddd;background:white;cursor:pointer;font-size:11px;color:#666;text-align:center;line-height:1.3;font-weight:600;transition:all .15s;}
.bld-tab.active{background:#185FA5;border-color:#185FA5;color:white;}

/* 수납바 */
.sum-bar-wrap{background:white;border:1px solid #e8e8e8;border-radius:14px;padding:12px 14px;margin-bottom:10px;}
.bar-wrap{display:flex;border-radius:12px;overflow:hidden;height:26px;margin-top:6px;}
.bar-paid{background:#2ECC71;display:flex;align-items:center;justify-content:center;font-size:11px;color:white;font-weight:700;}
.bar-unpaid{background:#E24B4A;display:flex;align-items:center;justify-content:center;font-size:11px;color:white;font-weight:700;}

/* 통계 카드 - 대시보드 3개 */
.stat-grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:10px;}
.stat-card{background:white;border:1px solid #e8e8e8;border-radius:12px;padding:14px 8px;text-align:center;cursor:pointer;transition:all .15s;}
.stat-card:active{transform:scale(.97);}
.stat-n{font-size:26px;font-weight:700;line-height:1;}
.stat-l{font-size:11px;color:#888;margin-top:4px;font-weight:600;}

/* 캘린더 */
.cal-card{background:white;border:1px solid #e8e8e8;border-radius:14px;padding:12px 14px;margin-bottom:10px;}
.cal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;}
.cal-month{font-size:14px;font-weight:700;color:#111;}
.cal-nav-row{display:flex;gap:4px;}
.cal-nav-btn{width:28px;height:28px;border-radius:7px;border:1px solid #ddd;background:white;cursor:pointer;font-size:14px;color:#333;}
.cal-leg{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:8px;}
.leg{display:flex;align-items:center;gap:4px;font-size:10px;color:#888;}
.leg-dot{width:8px;height:8px;border-radius:50%;}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;}
.cal-dow{text-align:center;font-size:10px;color:#aaa;padding:3px 0;font-weight:600;}
.cal-day{min-height:32px;border-radius:6px;padding:2px 3px;cursor:pointer;}
.cal-day:active{background:#f0f4ff;}
.dn{font-size:11px;color:#888;}
.cal-day.today{border:2px solid #185FA5;}
.cal-day.today .dn{color:#185FA5;font-weight:700;}
.cal-day.other .dn{color:#ccc;}
.cal-dots{display:flex;flex-wrap:wrap;gap:2px;margin-top:1px;}
.cdot{width:5px;height:5px;border-radius:50%;}
.ev-list{margin-top:8px;display:flex;flex-direction:column;gap:5px;}
.ev-row{display:flex;align-items:flex-start;gap:8px;padding:7px 9px;background:#f8f8f8;border-radius:8px;}
.ev-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:3px;}
.ev-main{font-size:12px;color:#111;flex:1;}
.ev-room{font-size:10px;color:#888;}

/* 메뉴 그리드 */
.menu-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-bottom:10px;}
.menu-btn{background:white;border:1px solid #e8e8e8;border-radius:12px;padding:14px 12px;display:flex;align-items:center;gap:10px;cursor:pointer;transition:all .15s;}
.menu-btn:active{background:#f8f8f8;transform:scale(.98);}
.m-icon{width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:19px;flex-shrink:0;}
.m-text{font-size:13px;font-weight:700;color:#111;}
.m-sub{font-size:10px;color:#999;margin-top:1px;}

/* 세입자 관리 */
.filter-bar{display:grid;grid-template-columns:repeat(4,1fr);gap:5px;margin-bottom:10px;}
.fb{padding:9px 4px;border-radius:10px;border:1px solid #ddd;background:white;cursor:pointer;font-size:12px;color:#666;text-align:center;font-weight:600;transition:all .15s;}
.fb.active{color:white;border-color:transparent;}
.fb.fb-all.active{background:#185FA5;}
.fb.fb-overdue.active{background:#E24B4A;}
.fb.fb-vacant.active{background:#888;}
.fb.fb-expiring.active{background:#E8A020;}
.search-box{position:relative;margin-bottom:10px;}
.search-box input{width:100%;padding:10px 12px 10px 36px;border-radius:10px;border:1px solid #ddd;font-size:13px;color:#111;outline:none;background:white;}
.search-box input:focus{border-color:#185FA5;}
.search-icon{position:absolute;left:12px;top:50%;transform:translateY(-50%);font-size:14px;color:#bbb;pointer-events:none;}

/* 세입자 카드 */
.tenant-card{background:white;border:1px solid #e8e8e8;border-radius:14px;overflow:hidden;margin-bottom:10px;}
.tc-header{display:flex;align-items:center;gap:10px;padding:13px 14px 0;}
.tc-av{width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;flex-shrink:0;}
.tc-info{flex:1;min-width:0;}
.tc-name{font-size:15px;font-weight:700;color:#111;}
.tc-room{font-size:11px;color:#999;margin-top:1px;}
.tc-overdue-amount{font-size:18px;font-weight:700;color:#E24B4A;padding:6px 14px 0;letter-spacing:-.5px;}
.tc-detail{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;padding:10px 14px;border-top:1px solid #f5f5f5;margin-top:10px;}
.td-i{text-align:center;}
.td-l{font-size:10px;color:#aaa;font-weight:600;}
.td-v{font-size:12px;font-weight:700;color:#333;margin-top:2px;}
.td-v.red{color:#E24B4A;}
.td-v.orange{color:#E8A020;}
.tc-btn-row{display:grid;gap:5px;padding:8px 14px 13px;}
.tc-btns-4{grid-template-columns:repeat(4,1fr);}
.tc-btns-2{grid-template-columns:repeat(2,1fr);}
.tcb{padding:8px 4px;border-radius:8px;border:1px solid #ddd;background:white;font-size:11px;color:#555;cursor:pointer;text-align:center;font-weight:600;transition:all .15s;font-family:inherit;}
.tcb:active{transform:scale(.97);}
.tcb.primary{background:#185FA5;border-color:#185FA5;color:white;}
.tcb.success{background:#1D9E75;border-color:#1D9E75;color:white;}
.tcb.danger{background:#FCEBEB;border-color:#FCEBEB;color:#A32D2D;}

/* 납입현황 */
.pay-summary{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:12px;}
.ps-card{border-radius:12px;padding:14px 8px;text-align:center;}
.ps-card.total{background:#E6F1FB;}
.ps-card.paid{background:#EAF3DE;}
.ps-card.unpaid{background:#FCEBEB;}
.ps-n{font-size:20px;font-weight:700;}
.ps-n.blue{color:#185FA5;}
.ps-n.green{color:#1D9E75;}
.ps-n.red{color:#E24B4A;}
.ps-l{font-size:10px;font-weight:600;color:#888;margin-top:3px;}
.ledger-table{width:100%;border-collapse:collapse;font-size:12px;}
.ledger-table th{background:#f5f5f5;padding:8px 7px;text-align:center;font-weight:700;color:#666;border-bottom:1px solid #e8e8e8;white-space:nowrap;}
.ledger-table td{padding:8px 7px;text-align:center;border-bottom:1px solid #f5f5f5;color:#333;}
.ledger-table td.left{text-align:left;font-weight:700;}
.ledger-table tbody tr:hover{background:#fafafa;}
.p-amt{color:#1D9E75;font-weight:700;}
.u-amt{color:#E24B4A;font-weight:700;}
.tfoot-row td{font-weight:700;background:#f8f8f8;border-top:2px solid #e8e8e8;}
.st-pill{padding:3px 7px;border-radius:20px;font-size:10px;font-weight:700;}
.quick-amt-row{display:flex;gap:6px;flex-wrap:wrap;margin-top:6px;}
.qa-btn{padding:8px 12px;border-radius:8px;border:1.5px solid #185FA5;background:white;cursor:pointer;font-size:12px;color:#185FA5;font-weight:700;transition:all .15s;font-family:inherit;}
.qa-btn:active{background:#E6F1FB;}
.qa-reset{padding:8px 12px;border-radius:8px;border:1px solid #ddd;background:white;cursor:pointer;font-size:12px;color:#888;font-weight:600;font-family:inherit;}
.amount-display{font-size:22px;font-weight:700;color:#111;padding:10px 0 4px;}

/* 민원 */
.complaint-card{background:white;border:1px solid #e8e8e8;border-radius:14px;overflow:hidden;margin-bottom:10px;}
.complaint-card.urgent{border-color:#F09595;border-width:2px;}
.cc-urgent-bar{background:#FCEBEB;padding:6px 14px;font-size:11px;color:#A32D2D;font-weight:700;}
.cc-top{display:flex;align-items:center;gap:10px;padding:12px 14px 0;}
.cc-cat-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;}
.cc-body{flex:1;min-width:0;}
.cc-title{font-size:13px;font-weight:700;color:#111;}
.cc-sub{font-size:11px;color:#999;margin-top:2px;}
.cc-desc{padding:6px 14px 8px;font-size:12px;color:#555;line-height:1.6;}
.cc-detail-row{display:grid;grid-template-columns:1fr 1fr;gap:6px;padding:8px 14px;border-top:1px solid #f5f5f5;}
.cc-btns{display:flex;gap:5px;padding:6px 14px 12px;}
.cc-btn{flex:1;padding:8px 4px;border-radius:8px;border:1px solid #ddd;background:white;font-size:11px;color:#555;cursor:pointer;text-align:center;font-weight:600;font-family:inherit;}
.cc-btn:active{background:#f5f5f5;}
.cc-btn.primary{background:#185FA5;border-color:#185FA5;color:white;}
.cc-btn.success{background:#1D9E75;border-color:#1D9E75;color:white;}
.cc-btn.warning{background:#FAEEDA;border-color:#FAC775;color:#7a4200;}

/* 민원 분류 토글 */
.cat-toggle-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;}
.cat-tog{padding:8px 4px;border-radius:8px;border:1px solid #ddd;background:white;cursor:pointer;font-size:11px;color:#555;text-align:center;font-weight:600;transition:all .15s;font-family:inherit;}
.cat-tog.on{border-color:#185FA5;background:#E6F1FB;color:#0C447C;}

/* 메모 */
.memo-card{background:white;border:1px solid #e8e8e8;border-radius:14px;overflow:hidden;margin-bottom:10px;}
.mc-top{display:flex;align-items:center;gap:10px;padding:12px 14px 0;}
.mc-av{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;flex-shrink:0;}
.mc-name{font-size:13px;font-weight:700;color:#111;}
.mc-room{font-size:11px;color:#999;}
.mc-body{padding:6px 14px 8px;font-size:12px;color:#555;line-height:1.65;white-space:pre-wrap;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;}
.mc-footer{border-top:1px solid #f5f5f5;padding:7px 14px;display:flex;align-items:center;justify-content:space-between;}

/* 옵션 체크 */
.option-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-top:6px;}
.opt-btn{padding:9px 6px;border-radius:8px;border:1px solid #ddd;background:white;cursor:pointer;font-size:12px;color:#555;text-align:center;font-weight:600;transition:all .15s;font-family:inherit;}
.opt-btn.on{background:#E6F1FB;border-color:#185FA5;color:#0C447C;}
.opt-btn:active{transform:scale(.97);}

/* 서명 팝업 */
.sig-popup-bg{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.6);z-index:999;align-items:center;justify-content:center;}
.sig-popup-bg.open{display:flex;}
.sig-popup{background:white;border-radius:16px;padding:20px;width:90%;max-width:400px;}
.sig-popup-title{font-size:15px;font-weight:700;color:#111;margin-bottom:12px;}
canvas.sig-big{display:block;width:100%;height:160px;border:2px dashed #ddd;border-radius:10px;cursor:crosshair;touch-action:none;}
.sig-popup-btns{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-top:12px;}

/* 계약서 */
.paper{background:white;border:1px solid #ccc;border-radius:10px;padding:18px 16px;color:#111;font-size:11.5px;}
.paper-title{text-align:center;font-size:18px;font-weight:700;letter-spacing:6px;margin-bottom:14px;padding-bottom:10px;border-bottom:2.5px solid #111;}
.sf{display:inline-block;position:relative;vertical-align:baseline;}
.sf-val{display:inline-block;border-bottom:1.5px solid #999;cursor:pointer;padding:1px 16px 1px 3px;color:#111;min-width:28px;position:relative;white-space:nowrap;font-size:11.5px;}
.sf-val::after{content:'▾';position:absolute;right:1px;top:1px;font-size:8px;color:#888;}
.sf-val:active{background:#eef4ff;}
.sf-drop{display:none;position:absolute;top:calc(100% + 2px);left:0;z-index:300;background:white;border:1.5px solid #185FA5;border-radius:8px;min-width:80px;box-shadow:0 4px 16px rgba(0,0,0,.15);overflow:hidden;}
.sf-drop.open{display:block;}
.sf-drop.scroll{max-height:180px;overflow-y:auto;}
.sf-opt{padding:8px 12px;cursor:pointer;font-size:12px;color:#111;white-space:nowrap;}
.sf-opt:active,.sf-opt:hover{background:#E6F1FB;color:#185FA5;}
.sf-opt.on{background:#185FA5;color:white;}
.tf input{border:none;border-bottom:1.5px solid #999;outline:none;background:transparent;font-size:11.5px;color:#111;font-family:inherit;padding:1px 2px;}
.tf input:focus{border-bottom-color:#185FA5;}
.tf input::placeholder{color:#ccc;}
table.ct{width:100%;border-collapse:collapse;margin-bottom:5px;font-size:11px;}
table.ct td{border:1px solid #bbb;padding:5px 6px;vertical-align:middle;}
table.ct .lbl{background:#f0f0f0;font-weight:700;white-space:nowrap;text-align:center;font-size:10px;}
.cw{font-size:10.5px;line-height:1.9;margin-bottom:6px;}
.cw p{margin-bottom:2px;}
.cn{font-weight:700;margin-right:2px;}
.sp-lbl{font-size:11px;font-weight:700;margin:8px 0 3px;border-left:3px solid #555;padding-left:5px;}
.sp-box{border:1px solid #ccc;border-radius:4px;}
.sp-box textarea{width:100%;border:none;outline:none;font-size:10px;line-height:1.85;resize:vertical;min-height:85px;font-family:inherit;color:#111;background:transparent;padding:6px 8px;}
.sign-date{text-align:center;font-size:12px;font-weight:700;margin:12px 0 6px;}

/* 서명란 - 페이지 맞게 */
table.sig-t{width:100%;border-collapse:collapse;font-size:10px;}
table.sig-t td{border:1px solid #bbb;padding:4px 5px;vertical-align:middle;}
.sig-t .sh{background:#f0f0f0;font-weight:700;text-align:center;white-space:nowrap;font-size:10px;width:36px;}
.sig-t .slbl{background:#f7f7f7;font-weight:700;text-align:center;font-size:9px;width:28px;}
.sig-thumb-wrap{display:flex;align-items:center;gap:4px;}
.sig-thumb{height:36px;border:1px dashed #ccc;border-radius:4px;flex:1;cursor:pointer;background:#fafafa;display:flex;align-items:center;justify-content:center;font-size:10px;color:#bbb;}
.sig-thumb canvas{width:100%;height:100%;display:block;}
.sig-thumb.has-sig{background:white;border-style:solid;border-color:#185FA5;}
.sig-clear-sm{padding:3px 6px;border:1px solid #ddd;border-radius:4px;background:white;cursor:pointer;font-size:9px;color:#888;flex-shrink:0;font-family:inherit;}

/* 상세정보 탭 */
.detail-tabs{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;margin-bottom:12px;}
.dt{padding:9px 4px;border-radius:10px;border:1px solid #ddd;background:white;cursor:pointer;font-size:12px;color:#666;text-align:center;font-weight:700;transition:all .15s;}
.dt.active{background:#185FA5;border-color:#185FA5;color:white;}

/* 사진 업로드 */
.photo-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:6px;}
.photo-slot{aspect-ratio:1;border-radius:10px;border:2px dashed #ddd;background:#fafafa;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;overflow:hidden;font-size:10px;color:#bbb;text-align:center;transition:all .15s;}
.photo-slot:active{background:#f0f4ff;}
.photo-slot img{width:100%;height:100%;object-fit:cover;}

/* 등록 폼 스텝 */
