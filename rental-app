function saveGsheetUrl(){
  const url = document.getElementById('gsheet-url-input')?.value.trim();
  if(!url){ alert('URL을 입력해주세요.'); return; }
  SCRIPT_URL = url;
  localStorage.setItem('gsheet_url', url);
  const el=document.getElementById('sync-status-bar2');
  if(el){el.style.display='block';el.style.background='#EAF3DE';el.style.color='#2d6b11';el.textContent='✅ URL이 저장되었습니다. 연결 테스트를 해보세요.';}
}

async function testGsheetConnection(){
  const inputEl = document.getElementById('gsheet-url-input');
  const url = (inputEl?.value.trim()) || SCRIPT_URL;
  if(!url){ alert('URL을 먼저 입력하고 저장해주세요.'); return; }
  // 입력한 URL이 library URL이면 경고
  if(url.includes('/library/')){
    const el=document.getElementById('sync-status-bar2');
    if(el){el.style.display='block';el.style.background='#FCEBEB';el.style.color='#A32D2D';el.textContent='❌ 잘못된 URL! /macros/s/...로 시작하는 URL을 입력하세요.';}
    return;
  }
  const el=document.getElementById('sync-status-bar2');
  if(el){el.style.display='block';el.style.background='#FAEEDA';el.style.color='#7a4200';el.textContent='⏳ 연결 테스트 중...';}
  try {
    const pingUrl = url.replace('/exec','') + '/exec?action=ping';
    const res = await fetch(pingUrl, {method:'GET', mode:'cors'});
    const json = await res.json();
    if(json.ok){
      SCRIPT_URL = url;
      localStorage.setItem('gsheet_url', url);
      if(el){el.style.background='#EAF3DE';el.style.color='#2d6b11';el.textContent='✅ 연결 성공! 이제 데이터 업로드 버튼을 눌러주세요.';}
    } else {
      if(el){el.style.background='#FCEBEB';el.style.color='#A32D2D';el.textContent='❌ 서버 오류: '+json.error;}
    }
  } catch(e){
    // URL 형식 확인
    if(url.includes('script.google.com/macros/s/') && url.includes('/exec')){
      SCRIPT_URL = url;
      localStorage.setItem('gsheet_url', url);
      if(el){el.style.background='#FAEEDA';el.style.color='#7a4200';el.textContent='⚠ CORS 오류 - 스크립트 배포 설정을 확인하세요. (액세스: 모든 사용자)';}
    } else {
      if(el){el.style.background='#FCEBEB';el.style.color='#A32D2D';el.textContent='❌ URL 형식 오류. /exec 로 끝나는 URL이어야 합니다.';}
    }
  }
}

async function uploadToGsheet(){
  const url = (document.getElementById('gsheet-url-input')?.value.trim()) || SCRIPT_URL;
  if(!url){ alert('URL을 먼저 입력해주세요.'); return; }
  SCRIPT_URL = url;
  localStorage.setItem('gsheet_url', url);
  const el=document.getElementById('sync-status-bar2');
  if(el){el.style.display='block';el.style.background='#FAEEDA';el.style.color='#7a4200';el.textContent='⏳ 업로드 중... (10~20초 소요)';}

  // 로컬에 먼저 저장
  const data = {
    TENANTS:TENANTS, COMPLAINTS:COMPLAINTS, MEMOS:MEMOS,
    PAY_DATA:PAY_DATA, contracts:contracts, tenantOptions:tenantOptions,
    lastSaved:new Date().toISOString(), savedBy:curUser||'boss'
  };
  try{ localStorage.setItem(SYNC_KEY, JSON.stringify(data)); }catch(e){}

  try {
    const dataStr = encodeURIComponent(JSON.stringify(data));
    const fullUrl = url + '?action=save&data=' + dataStr;
    const ctrl = new AbortController();
    const timer = setTimeout(()=>ctrl.abort(), 20000);
    const res = await fetch(fullUrl, {method:'GET', mode:'cors', signal:ctrl.signal});
    clearTimeout(timer);
    const json = await res.json();
    if(json.ok){
      if(el){el.style.background='#EAF3DE';el.style.color='#2d6b11';el.textContent='✅ 업로드 완료! 직원들에게 파일 전송하세요.';}
    } else {
      if(el){el.style.background='#FCEBEB';el.style.color='#A32D2D';el.textContent='❌ 오류: '+(json.error||'알 수 없음');}
    }
  } catch(e){
    if(el){el.style.background='#FCEBEB';el.style.color='#A32D2D';el.textContent='❌ 연결 실패: '+e.message+' (CORS 오류면 스크립트 재배포 필요)';}
  }
}

