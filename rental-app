let evictedTenants = []; // 퇴거 복구용 백업

function doEvict(tid){
  const t = TENANTS.find(x=>x.id===tid);
  if(!t) return;
  if(t.status==='vacant'){ alert('이미 공실 처리된 호실입니다.'); return; }

  // 폰에서 confirm 대신 커스텀 팝업 사용
  showEvictPopup(tid);
}

function showEvictPopup(tid){
  const t = TENANTS.find(x=>x.id===tid);
  if(!t) return;

  // 기존 팝업 제거
  const existing = document.getElementById('evict-popup-bg');
  if(existing) existing.remove();

  const unpaid = t.overdue||0;
  const popup = document.createElement('div');
  popup.id = 'evict-popup-bg';
  popup.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.6);z-index:9999;display:flex;align-items:center;justify-content:center;padding:16px;';
  popup.innerHTML = `<div style="background:white;border-radius:16px;padding:24px 20px;width:100%;max-width:340px;">
    <div style="font-size:18px;font-weight:700;color:#E24B4A;margin-bottom:6px;">퇴거 처리</div>
