function saveExtend(tid){
  const t=TENANTS.find(x=>x.id===tid);if(!t)return;
  const newEnd=document.getElementById('extend-end')?.value;
  if(!newEnd){showAppAlert('새 종료일을 입력해주세요.');return;}
  const oldEnd=t.end;
