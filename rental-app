function renderPayList(){
  try{ syncAllTenantStatus(); }catch(e){}
  renderPaySummaryCards();
  const today = new Date();
  const ym = today.getFullYear()+'-'+pad(today.getMonth()+1);

  // 전체 호실 포함 (공실 포함) - ALL_ROOMS 기반
  let list = [];
  if(payListBld === 'all'){
    // 전체 건물 ALL_ROOMS 기반
    ['mj','dg','sj'].forEach(bld=>{
      (ALL_ROOMS[bld]||[]).forEach(room=>{
        const found = TENANTS.find(t=>t.bld===bld && t.room===room+'호');
        if(found) list.push(found);
        else list.push({id:'v_'+bld+'_'+room, bld, room:room+'호', name:'공실', phone:'-', rent:0, deposit:0, start:'-', end:'-', status:'vacant', overdue:0, color:'#F1EFE8', tc:'#888', virtual:true});
      });
    });
  } else {
    (ALL_ROOMS[payListBld]||[]).forEach(room=>{
      const found = TENANTS.find(t=>t.bld===payListBld && t.room===room+'호');
      if(found) list.push(found);
      else list.push({id:'v_'+payListBld+'_'+room, bld:payListBld, room:room+'호', name:'공실', phone:'-', rent:0, deposit:0, start:'-', end:'-', status:'vacant', overdue:0, color:'#F1EFE8', tc:'#888', virtual:true});
    });
  }

  // 각 세입자/공실 상태 계산
  list = list.map(t=>{
    // 공실 처리
    if(t.status==='vacant'){
      return {...t, statusType:'vacant', statusLabel:'⬜ 공실', statusBg:'#F1EFE8', statusTc:'#888', amountLabel:'공실', amountColor:'#aaa', realUnpaid:0, paidThisMonth:0};
    }
    const realUnpaid = calcRealUnpaid(t);
    const entries = (PAY_DATA[t.id]&&PAY_DATA[t.id][ym])||[];
    const paidThisMonth = entries.reduce((s,r)=>s+r.amt,0);
    const payDay = t.start&&t.start!=='-' ? new Date(t.start).getDate() : 1;
    const dueDate = new Date(today.getFullYear(), today.getMonth(), payDay);
    const daysUntilDue = Math.ceil((dueDate - today)/864e5);
    // 종료임박: 60일(2개월) 이내
    const daysToEnd = t.end&&t.end!=='-' ? Math.ceil((new Date(t.end)-today)/864e5) : 9999;
    const isExpiring = daysToEnd >= 0 && daysToEnd <= 60;

    let statusType, statusLabel, statusBg, statusTc, amountLabel, amountColor;

    if(realUnpaid > 0){
      statusType='unpaid'; statusLabel='🔴 체납'; statusBg='#FCEBEB'; statusTc='#A32D2D';
      amountLabel='-'+realUnpaid.toLocaleString()+'원'; amountColor='#E24B4A';
    } else if(isExpiring){
      statusType='expiring'; statusLabel='🟡 종료 '+daysToEnd+'일 전'; statusBg='#FAEEDA'; statusTc='#7a4200';
      amountLabel=t.rent.toLocaleString()+'원'; amountColor='#E8A020';
    } else if(paidThisMonth >= t.rent){
      statusType='paid'; statusLabel='✅ 납부완료'; statusBg='#EAF3DE'; statusTc='#2d6b11';
      amountLabel='+'+paidThisMonth.toLocaleString()+'원'; amountColor='#1D9E75';
    } else if(daysUntilDue >= 0 && daysUntilDue <= 7){
      statusType='due_soon'; statusLabel='🟡 '+(daysUntilDue===0?'오늘 납부일':daysUntilDue+'일 후 납부'); statusBg='#FAEEDA'; statusTc='#7a4200';
      amountLabel=t.rent.toLocaleString()+'원'; amountColor='#E8A020';
    } else {
      statusType='upcoming'; statusLabel='⬜ '+(daysUntilDue>0?daysUntilDue+'일 후 납부일':'납부 대기'); statusBg='#f5f5f5'; statusTc='#888';
      amountLabel=t.rent.toLocaleString()+'원'; amountColor='#aaa';
    }
    return {...t, statusType, statusLabel, statusBg, statusTc, amountLabel, amountColor, realUnpaid, paidThisMonth, daysToEnd};
  });

  // 필터 적용
  if(payListFilter==='unpaid') list=list.filter(t=>t.statusType==='unpaid');
  else if(payListFilter==='expiring') list=list.filter(t=>t.statusType==='expiring');
  else if(payListFilter==='vacant') list=list.filter(t=>t.statusType==='vacant');

  // 필터가 없을 때는 호실 번호 순서대로, 필터 있을 때도 호실 순서
  list.sort((a,b)=>{
    // 같은 건물이면 호실 번호 순서
    if(a.bld===b.bld){
      const aNum = parseInt(a.room) || 0;
      const bNum = parseInt(b.room) || 0;
      return aNum - bNum;
    }
    // 다른 건물이면 mj → dg → sj 순서
    const bldOrder = {mj:0, dg:1, sj:2};
    return (bldOrder[a.bld]||0) - (bldOrder[b.bld]||0);
  });

  const el=document.getElementById('pay-list-items');
  if(!list.length){el.innerHTML='<div class="empty" style="padding:30px;text-align:center;color:#aaa;">해당 항목이 없습니다.</div>';return;}

