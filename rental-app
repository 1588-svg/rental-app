function toggleSmsRecv(id){smsSelIds.has(id)?smsSelIds.delete(id):smsSelIds.add(id);renderSmsRecv();}
function toggleAllSms(){const l=getSmsFiltered();if(smsSelIds.size===l.length)smsSelIds.clear();else l.forEach(t=>smsSelIds.add(t.id));renderSmsRecv();}
function quickSelSms(type){smsSelIds.clear();getSmsFiltered().forEach(t=>{if(type==='overdue'&&t.status==='overdue')smsSelIds.add(t.id);else if(type==='expiring'&&t.status==='expiring')smsSelIds.add(t.id);else if(type==='all')smsSelIds.add(t.id);});renderSmsRecv();}
